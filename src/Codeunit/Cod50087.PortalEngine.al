                            loanTypeJson.Add('is_mobile_loan', loansProducts."Is Mobile Loan?");
                            loanTypeJson.Add('maximum_installments', loansProducts."Default Installements");
                            loanTypeJson.Add('interest_calculation_method', Format(loansProducts."Repayment Method"));
                            loanTypes.Add(loanTypeJson);
                            Clear(loanTypeJson);
                        until loansProducts.Next() = 0;
                        SetResponseStatus(ResponseJson, 'success', 'Success', 'Loan application product list has been fetched successfully');
                    end else
                        SetResponseStatus(ResponseJson, 'error', 'Error', 'No loan products exist');
                end;
                if cust."Insider Status" = cust."Insider Status"::"Regular Member" then begin
                    loansProducts.Reset();
                    loansProducts.SetFilter(Code, '<>%1', '');
                    loansProducts.SetRange(InActive, false);
                    loansProducts.SetRange("Portal Application Source", true);
                    loansProducts.SetRange("Member Category", loansProducts."Member Category"::"All Members");
                    if loansProducts.FindSet() then begin
                        repeat
                            loanTypeJson.Add('product_id', loansProducts.Code);
                            loanTypeJson.Add('product_name', loansProducts."Product Description");
                            loanTypeJson.Add('minimum_guarantors', loansProducts."Min No. Of Guarantors");
                            loanTypeJson.Add('maximum_guarantors', loansProducts."Max No. Of Guarantor");
                            loanTypeJson.Add('minimum_amount', loansProducts."Min. Loan Amount");
                            loanTypeJson.Add('maximum_amount', loansProducts."Max. Loan Amount");
                            loanTypeJson.Add('max_salaried', loansProducts."Maximimum Amount Salaried");
                            loanTypeJson.Add('max_non_salaried', loansProducts."Maximimum Amount Non-Salaried");
                            loanTypeJson.Add('recovery_mode', Format(loansProducts."Recovery Mode"));
                            loanTypeJson.Add('repayment_frequency', Format(loansProducts."Repayment Frequency"));

                            if (loansProducts.Code = 'A03') or (loansProducts.Code = 'A16') then begin
                                Maxloan := mobileEngine.FnGetMobileAdvanceEligibility(cust."FOSA Account No.", loansProducts.Code, Msg, loansProducts."Max. Loan Amount", loansProducts."Default Installements");
                            end;
                            if loansProducts.Code = 'A01' then begin
                                Maxloan := mobileEngine.GetSalaryLoanQualifiedAmount(cust."FOSA Account No.", loansProducts.Code, loansProducts."Max. Loan Amount", Msg, loansProducts."Default Installements")
                            end;
                            if loansProducts.Code = 'M_OD' then begin
                                Maxloan := mobileEngine.GetOverdraftLoanQualifiedAmount(cust."FOSA Account No.", loansProducts.Code, loansProducts."Max. Loan Amount", Msg)
                            end;
                            if loansProducts.Code = 'A10' then begin
                                Maxloan := mobileEngine.GetReloadedLoanQualifiedAmount(cust."FOSA Account No.", loansProducts.Code, loansProducts."Max. Loan Amount", Msg, loansProducts."Default Installements")
                            end;
                            if loansProducts."Is Mobile Loan?" = false then begin
                                Maxloan := FnGetMemberLoanEligibility(cust."No.", loansProducts.Code);
                            end;

                            loanTypeJson.Add('eligible_amount', Maxloan);
                            loanTypeJson.Add('is_mobile_loan', loansProducts."Is Mobile Loan?");
                            loanTypeJson.Add('maximum_installments', loansProducts."Default Installements");
                            loanTypeJson.Add('interest_calculation_method', Format(loansProducts."Repayment Method"));
                            loanTypes.Add(loanTypeJson);
                            Clear(loanTypeJson);
                        until loansProducts.Next() = 0;
                        SetResponseStatus(ResponseJson, 'success', 'Success', 'Loan application product list has been fetched successfully');
                    end else
                        SetResponseStatus(ResponseJson, 'error', 'Error', 'No loan products exist');
                end;
            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'PAYROLL_NO' then begin
            cust.Reset();
            cust.SetRange("Payroll No", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'ID_NO' then begin
            cust.Reset();
            cust.SetRange("ID No.", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'EMAIL' then begin
            cust.Reset();
            cust.SetRange("E-Mail", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;

        ResponseJson.Add(Data, loanTypes);
        ResponseJson.Add(dateTime, CurrentDateTime);
    end;

    local procedure GetLoanPurpose(RequestJson: JsonObject) ResponseJson: JsonObject
    var
