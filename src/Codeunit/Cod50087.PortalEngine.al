                            EntryType := 'Debit'
                        else
                            EntryType := 'Credit';

                        TransactionObject.Add('entry_number', TransactionList."Entry No.");
                        TransactionObject.Add('transaction_reference', TransactionList."Document No.");
                        TransactionObject.Add('posting_date', TransactionList."Posting Date");
                        TransactionObject.Add('description', TransactionList.Description);
                        TransactionObject.Add('amount', TransactionList.Amount);
                        TransactionObject.Add('running_balance', TransactionList."Running Balance");
                        TransactionObject.Add('entry_type', EntryType);
                        TransactionsArray.Add(TransactionObject);
                        Clear(TransactionObject);
                    end;
                end until (TransactionList.Next() = 0) or (Count >= LastRow);

                // Add pagination and summary information
                PageJson.Add('records', TransactionsArray);
                PageJson.Add('page', page_number);
                PageJson.Add('page_count', page_size);
                PageJson.Add('total_records', TotalFoundRecords);
                PageJson.Add('total_pages', Round(TotalFoundRecords / page_size, 1, '>'));
                PageJson.Add('credits', TotalCredits);
                PageJson.Add('debits', TotalDebits);
                PageJson.Add('open_balance', OpenBals);
            end;
        end else
