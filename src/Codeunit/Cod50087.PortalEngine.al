        if IdentifierType = 'MSISDN' then begin
            cust.Reset();
            cust.SetFilter("Mobile Phone No", '%1|%2|%3', Identifier, Identifier2, Identifier3);
            if cust.FindFirst() then begin
                sectors.Reset();
                sectors.SetFilter(Code, '<>%1', '');
                if sectors.FindSet() then begin
                    repeat
                        specificSectorJson.Add('code', sectors.Code);
                        specificSectorJson.Add('description', Format(sectors.Description));
                        specificSectors.Add(specificSectorJson);
                        Clear(specificSectorJson);
                    until sectors.Next() = 0;
                    SetResponseStatus(ResponseJson, 'success', 'Success', 'Get Loan purposes list has been fetched successfully');
                end;
            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'PAYROLL_NO' then begin
            cust.Reset();
            cust.SetRange("Payroll No", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'ID_NO' then begin
            cust.Reset();
            cust.SetRange("ID No.", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'EMAIL' then begin
            cust.Reset();
            cust.SetRange("E-Mail", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;

        ResponseJson.Add(Data, specificSectors);
        ResponseJson.Add(dateTime, CurrentDateTime);
    end;

    local procedure FnCheckIfHasRunningLoans(member: Code[20]; loanType: Code[20]): boolean
    var
        myInt: Integer;
    begin
        LoansRegister.Reset();
        LoansRegister.SetRange("Client Code", member);
        LoansRegister.SetRange("Loan Product Type", loanType);
        LoansRegister.SetAutoCalcFields("Total Outstanding Balance");
        LoansRegister.SetFilter("Total Outstanding Balance", '>%1', 0);
        if LoansRegister.Find('-') then begin
            exit(false);
        end else
            exit(true);
    end;

    local procedure CreateLoanApplicationRequest(RequestJson: JsonObject) ResponseJson: JsonObject
    var
        DataJson: JsonObject;
        IdentifierType: Text;
        Identifier: Text;
        LoanProduct: Text;
        LoanPurpose: Text;
        Installments: Integer;
        Amount: Decimal;
        // guarantorNo: array [20] of Text;
        // guaranteedAmount: array [20] of Decimal;
        guarantorNo: Text;
        msg: Text;
        guaranteedAmount: Decimal;
        RatingLoanLimit: Decimal;
        Maxloan: Decimal;
        errorFound: Boolean;
        Identifier2: Text;
        Identifier3: Text;
        errorMsg: Text;
        finalErrorMsg: Text;
        loanNo: Code[20];
        recoveryMode: Code[20];
        lineNo: Integer;
        genBatch: Code[20];
        genTemplate: Code[20];
        docNo: Code[20];
        LoanTypeID: Code[20];
        CreationMessage: Text[2500];
        Iterator: Integer;
        loanNoJson: JsonObject;
        guarJson: JsonArray;
        LoanApp: JsonArray;
        loansApplied: Variant;
        loansGuarantors: Variant;
        recRef: RecordRef;
        fieldVal: FieldRef;
        refDate: date;
        InterestAmount: Decimal;
        PChargeAmount: Decimal;
        noSeriesMngt: Codeunit "No. Series";
        mobileEngine: CodeUnit "Mobile Banking Engine";
        smsManagement: Codeunit "Sms Management";
        AUFactory: Codeunit "Au Factory";
        cust: Record Customer;
        member: Record Customer;
        loansReg: Record "Loans Register";
        loansRegII: Record "Loans Register";
        loanProducts: Record "Loan Products Setup";
        loanGuarantor: Record "Loans Guarantee Details";
        saccoNoSeries: Record "Sacco No. Series";
        generalBatch: Record "Gen. Journal Batch";
        generalJournal: Record "Gen. Journal Line";
        GenSetUp: Record "Sacco General Set-Up";
        PCharges: Record "Loan Product Charges";
        CreditRating: Record "Credit Rating";
    begin
        Iterator := 0;

        IdentifierType := SelectJsonToken(RequestJson, '$.identifier_type').AsValue.AsText;
        Identifier := SelectJsonToken(RequestJson, '$.identifier').AsValue.AsText;
        LoanProduct := SelectJsonToken(RequestJson, '$.loan_product').AsValue.AsText;
        LoanPurpose := SelectJsonToken(RequestJson, '$.loan_purpose').AsValue.AsText;
        Installments := SelectJsonToken(RequestJson, '$.installments').AsValue.AsInteger;
        Amount := SelectJsonToken(RequestJson, '$.requested_amount').AsValue.AsDecimal;

        Identifier2 := InsStr(Identifier, '+', 1);
        Identifier3 := DelChr(Identifier, '<', '254');
        Identifier3 := InsStr(Identifier3, '0', 1);

        saccoNoSeries.Get();
        if IdentifierType = 'MEMBER_NO' then begin
            cust.Reset();
            cust.SetRange("No.", Identifier);
            if cust.FindFirst() then begin
                if loanProducts.Get(LoanProduct) then begin
                    if not FnCheckIfHasRunningLoans(cust."No.", LoanProduct) then begin
                        errorMsg := 'You have an existing %1. Kindly select it for an offset to proceed.';
                        finalErrorMsg := StrSubstNo(errorMsg, loanProducts."Product Description");
                        SetResponseStatus(ResponseJson, 'fail', 'Fail', finalErrorMsg);
                    end else begin

                        if (LoanProduct = 'A03') or (LoanProduct = 'A16') then begin
                            Maxloan := mobileEngine.FnGetMobileAdvanceEligibility(cust."FOSA Account No.", LoanProduct, Msg, loanProducts."Max. Loan Amount", Installments);
                        end;
                        if LoanProduct = 'A01' then begin
                            Maxloan := mobileEngine.GetSalaryLoanQualifiedAmount(cust."FOSA Account No.", LoanProduct, loanProducts."Max. Loan Amount", Msg, Installments)
                        end;
                        if LoanProduct = 'M_OD' then begin
                            Maxloan := mobileEngine.GetOverdraftLoanQualifiedAmount(cust."FOSA Account No.", LoanProduct, loanProducts."Max. Loan Amount", Msg)
                        end;
                        if LoanProduct = 'A10' then begin
                            Maxloan := mobileEngine.GetReloadedLoanQualifiedAmount(cust."FOSA Account No.", LoanProduct, loanProducts."Max. Loan Amount", Msg, Installments)
                        end;
                        if loanProducts."Is Mobile Loan?" = false then begin
                            Maxloan := Amount;
                        end;


                        if Maxloan < Amount then begin

                            errorMsg := 'You can only qualify for upto KES %1 for this %2.';
                            finalErrorMsg := StrSubstNo(errorMsg, MaxLoan, loanProducts."Product Description");
                            SetResponseStatus(ResponseJson, 'fail', 'Fail', finalErrorMsg);

                        end else begin

                            loansRegII.Init;
                            loansRegII."Source." := LoanProducts."Source.";
                            loansRegII."Loan Application Mode" := loansRegII."Loan Application Mode"::Portal;
                            loansRegII."Client Code" := cust."No.";

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(4);
                            if FnTestValidate(RecRef, fieldVal, 1) = false then begin
                                errorMsg := GetLastErrorText + ' - 1 - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate("Client Code");
                            loansRegII."Loan Product Type" := LoanProduct;

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(3);
                            if FnTestValidate(RecRef, fieldVal, 2) = false then begin
                                errorMsg := GetLastErrorText + ' - 2 -  Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate("Loan Product Type");
                            loansRegII."Sector Specific" := LoanPurpose;

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(51516289);
                            if FnTestValidate(RecRef, fieldVal, 3) = false then begin
                                errorMsg := GetLastErrorText + ' - 3 - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate("Sector Specific");
                            loansRegII.Installments := Installments;

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(30);
                            if FnTestValidate(RecRef, fieldVal, 4) = false then begin
                                errorMsg := GetLastErrorText + ' - 4 - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate(Installments);
                            loansRegII."Requested Amount" := Amount;

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(8);
                            if FnTestValidate(RecRef, fieldVal, 5) = false then begin
                                errorMsg := GetLastErrorText + ' - 5 - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate("Requested Amount");
                            loansRegII."Mode of Disbursement" := loansRegII."Mode of Disbursement"::"FOSA Account";
                            loansRegII."Application Date" := Today;
                            loansRegII.Advice := true;
                            loansRegII."Captured By" := UpperCase(UserId);
                            loansRegII."Captured By Date" := Today;
                            loansRegII."Captured By Time" := Time;
                            if loanProducts.Source = loanProducts.Source::BOSA then begin
                                loanNo := noSeriesMngt.GetNextNo(saccoNoSeries."BOSA Loans Nos", Today, true);
                                loansRegII."Loan  No." := loanNo;
                            end else if loanProducts.Source = loanProducts.Source::FOSA then begin
                                loanNo := noSeriesMngt.GetNextNo(saccoNoSeries."FOSA Loans Nos", Today, true);
                                loansRegII."Loan  No." := loanNo;
                            end else begin
                                loanNo := noSeriesMngt.GetNextNo(saccoNoSeries."BOSA Loans Nos", Today, true);
                                loansRegII."Loan  No." := loanNo;
                            end;

                            if not errorFound then begin
                                loansRegII.Insert;
                            end;

                            loansReg.Reset;
                            if loansReg.Get(loanNo) then begin
                                if (loanProducts.Code = 'A03') or (loanProducts.Code = 'A16') or (loanProducts.Code = 'M_OD') then begin
                                    genTemplate := 'PAYMENTS';
                                    genBatch := 'PORTALLOAN';

                                    FnPrepJournal(genTemplate, genBatch);
                                    loansReg."Approved Amount" := loansReg."Requested Amount";
                                    loansReg."Recommended Amount" := loansReg."Requested Amount";
                                    loansReg.Modify;

                                    if (loanProducts.Code = 'A03') then begin
                                        RatingLoanLimit := mobileEngine.GetCreditRatingLimit(cust."No.", loansReg."Loan Product Type");
                                        CreditRating.INIT;
                                        CreditRating."Loan No." := loansReg."Loan  No.";
                                        CreditRating."Document Date" := TODAY;
                                        CreditRating."Loan Amount" := loansReg."Approved Amount";
                                        CreditRating."Date Entered" := TODAY;
                                        CreditRating."Time Entered" := TIME;
                                        CreditRating."Entered By" := USERID;
                                        CreditRating."Account No" := loansReg."Account No";
                                        CreditRating."Member No" := loansReg."Client Code";
                                        CreditRating."Telephone No" := cust."Mobile Phone No";
                                        CreditRating."Customer Name" := loansReg."Client Name";
                                        CreditRating."Loan Product Type" := loansReg."Loan Product Type";
                                        CreditRating."Loan Limit" := RatingLoanLimit;
                                        CreditRating."Staff No." := cust."Payroll No";
                                        CreditRating.INSERT;
                                    end;

                                    docNo := loanNo;
                                    lineNo := lineNo + 10000;
                                    AUFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::Loan, generalJournal."Account Type"::Customer, loansReg."Client Code", Today,
                                    loansReg."Approved Amount", 'BOSA', loanNo, loanProducts."Product Description" + ' - PORTAL', loanNo, generalJournal."Application Source"::Internet);

                                    lineNo := lineNo + 10000;
                                    AUFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ", generalJournal."Account Type"::Vendor, loansReg."Account No", Today,
                                    loansReg."Approved Amount" * -1, 'BOSA', loanNo, loanProducts."Product Description" + ' - PORTAL', loanNo, generalJournal."Application Source"::Internet);

                                    if (LoanTypeID = 'A01') or (LoanTypeID = 'A10') then begin
                                        PCharges.RESET;
                                        PCharges.SETRANGE(PCharges."Product Code", LoanTypeID);
                                        IF PCharges.FIND('-') THEN BEGIN
                                            REPEAT
                                                Amount := loansReg."Approved Amount";
                                                GenSetUp.Get();
                                                PCharges.TESTFIELD(PCharges."G/L Account");
                                                GenSetUp.TESTFIELD(GenSetUp."Excise Duty Account");
                                                IF PCharges."Use Perc" = TRUE THEN begin
                                                    PChargeAmount := (Amount * PCharges.Percentage / 100);
                                                end else
                                                    PChargeAmount := PCharges.Amount;
                                                //-------------------EARN CHARGE-------------------------------------------
                                                lineNo := lineNo + 10000;
                                                AuFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                                generalJournal."Account Type"::"G/L Account", PCharges."G/L Account", Today, PChargeAmount * -1, 'BOSA', loansReg."Loan  No.",
                                                PCharges.Description + ' - ' + loansReg."Client Code" + ' - ' + loansReg."Loan  No.", loansReg."Loan  No.", generalJournal."Application Source"::" ");
                                                //-------------------RECOVER-----------------------------------------------
                                                lineNo := lineNo + 10000;
                                                AuFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                                generalJournal."Account Type"::Vendor, loansReg."Account No", Today, PChargeAmount, 'BOSA', loansReg."Loan  No.",
                                                PCharges.Description + '-' + loansReg."Loan Product Type Name", loansReg."Loan  No.", generalJournal."Application Source"::" ");

                                                //------------------10% EXCISE DUTY----------------------------------------
                                                IF AuFactory.FnChargeExcise(PCharges.Code) THEN BEGIN
                                                    //-------------------Earn--------------------------------- 
                                                    lineNo := lineNo + 10000;
                                                    AuFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                                    generalJournal."Account Type"::"G/L Account", GenSetUp."Excise Duty Account", Today, (PChargeAmount * (GenSetUp."Excise Duty(%)" / 100)) * -1, 'BOSA', loansReg."Loan  No.",
                                                    PCharges.Description + '-' + loansReg."Client Code" + '-' + loansReg."Loan Product Type Name" + '-' + loansReg."Loan  No." + '- Excise Duty', loansReg."Loan  No.", generalJournal."Application Source"::" ");
                                                    //-----------------Recover---------------------------------
                                                    lineNo := lineNo + 10000;
                                                    AuFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                                    generalJournal."Account Type"::Vendor, loansReg."Account No", Today, (PChargeAmount * (GenSetUp."Excise Duty(%)" / 100)), 'BOSA', loansReg."Loan  No.",
                                                    PCharges.Description + '-' + loansReg."Loan Product Type Name" + ' - Excise Duty', loansReg."Loan  No.", generalJournal."Application Source"::" ");
                                                END
                                            //----------------END 10% EXCISE--------------------------------------------
                                            UNTIL PCharges.NEXT = 0;
                                        END;
                                    end;

                                    if (loanProducts."Charge Interest Upfront" <> true) and (loanProducts."Recovery Mode" = loanProducts."Recovery Mode"::Mobile) then begin
                                        InterestAmount := 0;
                                        if loansReg."Repayment Method" = loansReg."repayment method"::Amortised then begin
                                            InterestAmount := ROUND(loansReg."Approved Amount" / 100 / 12 * loanProducts."Interest rate", 1, '>');

                                        end;
                                        if loansReg."Repayment Method" = loansReg."repayment method"::"Reducing Balance" then begin
                                            InterestAmount := ROUND(loansReg."Approved Amount" * loanProducts."Interest rate" / 1200, 1, '>');

                                        end;

                                        if loansReg."Repayment Method" = loansReg."repayment method"::"Straight Line" then begin
                                            InterestAmount := Round((loanProducts."Interest rate" / 12 / 100) * loansReg."Approved Amount", 1, '>');
                                        end;

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Paid",
                                        generalJournal."Account Type"::Customer, loansReg."Client Code", Today, -InterestAmount, '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Upfront' + ' ' + cust."No.", loansReg."Loan  No.");

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Due",
                                        generalJournal."Account Type"::Customer, loansReg."Client Code", Today, InterestAmount, '', docNo,
                                        loanProducts."Product Description" + ' Loan ' + ' ' + cust."No.", loansReg."Loan  No.");

                                    end;
                                    if (loanProducts."Charge Interest Upfront" = true) and (loanProducts."Recover Upfront Interest" = true) then begin
                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                        generalJournal."Account Type"::"G/L Account", loanProducts."Loan Interest Account", Today, ((loansReg.Installments * loanProducts."Interest rate") * Amount / 100) * -1, '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Upfront' + ' ' + cust."No.", '');

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Due",
                                        generalJournal."Account Type"::Customer, loansReg."Client Code", Today, ((loansReg.Installments * loanProducts."Interest rate") * Amount / 100), '', docNo,
                                        loanProducts."Product Description" + ' Loan ' + ' ' + cust."No.", loansReg."Loan  No.");

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                        generalJournal."Account Type"::Vendor, cust."FOSA Account No.", Today, ((loansReg.Installments * loanProducts."Interest rate") * Amount / 100), '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Repayment' + ' ' + loansReg."Loan Product Type Name" + ' ' + cust."No.", '');

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Paid",
                                        generalJournal."Account Type"::Customer, cust."No.", Today, ((loansReg.Installments * loanProducts."Interest rate") * Amount / 100) * -1, '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Repayment' + ' ' + cust."No.", loansReg."Loan  No.");
                                    end;

                                    if (loanProducts."Charge Interest Upfront" = true) and (loanProducts."Recover Upfront Interest" = false) then begin
                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                        generalJournal."Account Type"::"G/L Account", loanProducts."Loan Interest Account", Today, (loansReg.Installments * loanProducts."Interest rate" * Amount / 100) * -1, '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Upfront' + ' ' + cust."No.", loansReg."Loan  No.");

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Due",
                                        generalJournal."Account Type"::Customer, loansReg."Client Code", Today, (loansReg.Installments * loanProducts."Interest rate" * Amount / 100), '', docNo,
                                        loanProducts."Product Description" + ' Loan ' + ' ' + cust."No.", loansReg."Loan  No.");
                                    end;

                                    loansReg."Loan Disbursement Date" := Today;
                                    loansReg."Disbursed By Time" := Time;
                                    loansReg."Disbursed By" := UserId;
                                    loansReg.Validate("Loan Disbursement Date");
                                    loansReg."Loan Status" := loansReg."Loan Status"::Issued;
                                    loansReg.Posted := true;
                                    loansReg.Modify;

                                    generalJournal.Reset;
                                    generalJournal.SetRange("Journal Template Name", genTemplate);
                                    generalJournal.SetRange("Journal Batch Name", genBatch);
                                    if generalJournal.FindSet() then begin
                                        Codeunit.Run(Codeunit::"Gen. Jnl.-Post Sacco", generalJournal);
                                    end;

                                    CreationMessage := 'Dear ' + BName.NameStyle(loansReg."Client Code") + ', your ' + loanProducts."Product Description" + ' loan has been disbursed to your FOSA Account.';
                                    smsManagement.SendSmsWithID(Source::LOAN_POSTED, BName.PhoneNo(loansReg."Client Code"), CreationMessage, loansReg."Client Code", loansReg."Account No", TRUE, 200, TRUE, 'CBS', CreateGuid(), 'CBS');

                                    SetResponseStatus(ResponseJson, 'success', 'Success', 'Loan application request has been created successfully');
                                    loanNoJson.Add('application_no', loanNo);
                                end;

                                if loanProducts."Requires Guarantors" or loanProducts."Requires Guarantors Mobile" then begin
                                    guarJson := SelectJsonToken(RequestJson, '$.guarantors').AsArray();
                                    Iterator := guarJson.Count;
                                    Iterator := Iterator - 1;
                                    while (Iterator >= 0) do begin
                                        guarantorNo := SelectJsonToken(RequestJson, '$.guarantors[' + Format(Iterator) + '].member_number').AsValue.AsText;

                                        loanGuarantor.Init();
                                        loanGuarantor."Loan No" := loanNo;
                                        loanGuarantor."Member No" := guarantorNo;

                                        loansGuarantors := loanGuarantor;
                                        recRef.GetTable(loansGuarantors);
                                        fieldVal := recRef.Field(2);

                                        if not FnTestValidate(recRef, fieldVal, 1) then begin
                                            errorMsg := GetLastErrorText + ' - Member No: ' + guarantorNo;
                                            errorFound := true;
                                        end else begin
                                            loanGuarantor.Validate("Member No");
                                            loanGuarantor.Insert;

                                            if member.Get(loanGuarantor."Member No") then begin
                                                CreationMessage := 'Dear ' + member."First Name" + ', you have been selected as a guarantor to ' + cust."First Name" + '''s ' + loansReg."Loan Product Type Name" + '. Kindly use the relevant channels to accept or reject this application.';
                                                smsManagement.SendSmsWithID(Source::LOAN_GUARANTORS, member."Mobile Phone No", CreationMessage, cust."No.", cust."FOSA Account No.", TRUE, 200, TRUE, 'Portal', CreateGuid(), 'Portal');
                                            end;
                                        end;
                                        Iterator := Iterator - 1;
                                    end;
                                    if errorFound then begin
                                        SetResponseStatus(ResponseJson, 'error', 'Error', errorMsg);
                                    end else begin
                                        SetResponseStatus(ResponseJson, 'success', 'Success', 'Loan application request has been created successfully');
                                        loanNoJson.Add('application_no', loanNo);
                                    end;
                                end;
                            end else
                                SetResponseStatus(ResponseJson, 'error', 'Error', 'Loan application failed:- ' + errorMsg);
                        end;
                    end;
                end else
                    SetResponseStatus(ResponseJson, 'error', 'Error', 'Loan product does not exist');
            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'MSISDN' then begin
            cust.Reset();
            cust.SetFilter("Mobile Phone No", '%1|%2|%3', Identifier, Identifier2, Identifier3);
            if cust.FindFirst() then begin
                if loanProducts.Get(LoanProduct) then begin
                    if not FnCheckIfHasRunningLoans(cust."No.", LoanProduct) then begin
                        errorMsg := 'You have an existing %1. Kindly select if for an offset to proceed.';
                        finalErrorMsg := StrSubstNo(errorMsg, loanProducts."Product Description");
                        SetResponseStatus(ResponseJson, 'fail', 'Fail', finalErrorMsg);
                    end else begin

                        if (LoanProduct = 'A03') or (LoanProduct = 'A16') then begin
                            Maxloan := mobileEngine.FnGetMobileAdvanceEligibility(cust."FOSA Account No.", LoanProduct, Msg, loanProducts."Max. Loan Amount", Installments);
                        end;
                        if LoanProduct = 'A01' then begin
                            Maxloan := mobileEngine.GetSalaryLoanQualifiedAmount(cust."FOSA Account No.", LoanProduct, loanProducts."Max. Loan Amount", Msg, Installments)
                        end;
                        if LoanProduct = 'M_OD' then begin
                            Maxloan := mobileEngine.GetOverdraftLoanQualifiedAmount(cust."FOSA Account No.", LoanProduct, loanProducts."Max. Loan Amount", Msg)
                        end;
                        if LoanProduct = 'A10' then begin
                            Maxloan := mobileEngine.GetReloadedLoanQualifiedAmount(cust."FOSA Account No.", LoanProduct, loanProducts."Max. Loan Amount", Msg, Installments)
                        end;
                        if loanProducts."Is Mobile Loan?" = false then begin
                            Maxloan := Amount;
                        end;

                        if Maxloan < Amount then begin

                            errorMsg := 'You can only qualify for upto KES %1 for this %2.';
                            finalErrorMsg := StrSubstNo(errorMsg, MaxLoan, loanProducts."Product Description");
                            SetResponseStatus(ResponseJson, 'fail', 'Fail', finalErrorMsg);

                        end else begin

                            loansRegII.Init;
                            loansRegII."Source." := LoanProducts."Source.";
                            loansRegII."Loan Application Mode" := loansRegII."Loan Application Mode"::Portal;
                            loansRegII."Client Code" := cust."No.";

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(4);
                            if FnTestValidate(RecRef, fieldVal, 1) = false then begin
                                errorMsg := GetLastErrorText + ' - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate("Client Code");
                            loansRegII."Loan Product Type" := LoanProduct;

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(3);
                            if FnTestValidate(RecRef, fieldVal, 2) = false then begin
                                errorMsg := GetLastErrorText + ' - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate("Loan Product Type");
                            loansRegII."Sector Specific" := LoanPurpose;

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(51516289);
                            if FnTestValidate(RecRef, fieldVal, 3) = false then begin
                                errorMsg := GetLastErrorText + ' - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate("Sector Specific");
                            loansRegII.Installments := Installments;

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(30);
                            if FnTestValidate(RecRef, fieldVal, 4) = false then begin
                                errorMsg := GetLastErrorText + ' - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate(Installments);
                            loansRegII."Requested Amount" := Amount;

                            loansApplied := loansRegII;
                            RecRef.GetTable(loansApplied);
                            fieldVal := recRef.Field(8);
                            if FnTestValidate(RecRef, fieldVal, 5) = false then begin
                                errorMsg := GetLastErrorText + ' - Member No: ' + cust."No.";
                                errorFound := true;
                            end else
                                loansRegII.Validate("Requested Amount");
                            loansRegII."Mode of Disbursement" := loansRegII."Mode of Disbursement"::"FOSA Account";
                            loansRegII."Application Date" := Today;
                            loansRegII.Advice := true;
                            loansRegII."Captured By" := UpperCase(UserId);
                            loansRegII."Captured By Date" := Today;
                            loansRegII."Captured By Time" := Time;
                            if loanProducts.Source = loanProducts.Source::BOSA then begin
                                loanNo := noSeriesMngt.GetNextNo(saccoNoSeries."BOSA Loans Nos", Today, true);
                                loansRegII."Loan  No." := loanNo;
                            end else if loanProducts.Source = loanProducts.Source::FOSA then begin
                                loanNo := noSeriesMngt.GetNextNo(saccoNoSeries."FOSA Loans Nos", Today, true);
                                loansRegII."Loan  No." := loanNo;
                            end else begin
                                loanNo := noSeriesMngt.GetNextNo(saccoNoSeries."BOSA Loans Nos", Today, true);
                                loansRegII."Loan  No." := loanNo;
                            end;

                            if not errorFound then begin
                                loansRegII.Insert;
                            end;

                            loansReg.Reset;
                            if loansReg.Get(loanNo) then begin
                                if (loanProducts.Code = 'A03') or (loanProducts.Code = 'A16') or (loanProducts.Code = 'M_OD') then begin
                                    genTemplate := 'PAYMENTS';
                                    genBatch := 'PORTALLOAN';

                                    FnPrepJournal(genTemplate, genBatch);
                                    loansReg."Approved Amount" := loansReg."Requested Amount";
                                    loansReg."Recommended Amount" := loansReg."Requested Amount";
                                    loansReg.Modify;

                                    if (loanProducts.Code = 'A03') then begin
                                        RatingLoanLimit := mobileEngine.GetCreditRatingLimit(cust."No.", loansReg."Loan Product Type");
                                        CreditRating.INIT;
                                        CreditRating."Loan No." := loansReg."Loan  No.";
                                        CreditRating."Document Date" := TODAY;
                                        CreditRating."Loan Amount" := loansReg."Approved Amount";
                                        CreditRating."Date Entered" := TODAY;
                                        CreditRating."Time Entered" := TIME;
                                        CreditRating."Entered By" := USERID;
                                        CreditRating."Account No" := loansReg."Account No";
                                        CreditRating."Member No" := loansReg."Client Code";
                                        CreditRating."Telephone No" := cust."Mobile Phone No";
                                        CreditRating."Customer Name" := loansReg."Client Name";
                                        CreditRating."Loan Product Type" := loansReg."Loan Product Type";
                                        CreditRating."Loan Limit" := RatingLoanLimit;
                                        CreditRating."Staff No." := cust."Payroll No";
                                        CreditRating.INSERT;
                                    end;

                                    docNo := loanNo;
                                    lineNo := lineNo + 10000;
                                    AUFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::Loan, generalJournal."Account Type"::Customer, loansReg."Client Code", Today,
                                    loansReg."Approved Amount", 'BOSA', loanNo, loanProducts."Product Description" + ' - PORTAL', loanNo, generalJournal."Application Source"::Internet);

                                    lineNo := lineNo + 10000;
                                    AUFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ", generalJournal."Account Type"::Vendor, loansReg."Account No", Today,
                                    loansReg."Approved Amount" * -1, 'BOSA', loanNo, loanProducts."Product Description" + ' - PORTAL', loanNo, generalJournal."Application Source"::Internet);

                                    if (LoanTypeID = 'A01') or (LoanTypeID = 'A10') then begin
                                        PCharges.RESET;
                                        PCharges.SETRANGE(PCharges."Product Code", LoanTypeID);
                                        IF PCharges.FIND('-') THEN BEGIN
                                            REPEAT
                                                Amount := loansReg."Approved Amount";
                                                GenSetUp.Get();
                                                PCharges.TESTFIELD(PCharges."G/L Account");
                                                GenSetUp.TESTFIELD(GenSetUp."Excise Duty Account");
                                                IF PCharges."Use Perc" = TRUE THEN begin
                                                    PChargeAmount := (Amount * PCharges.Percentage / 100);
                                                end else
                                                    PChargeAmount := PCharges.Amount;
                                                //-------------------EARN CHARGE-------------------------------------------
                                                lineNo := lineNo + 10000;
                                                AuFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                                generalJournal."Account Type"::"G/L Account", PCharges."G/L Account", Today, PChargeAmount * -1, 'BOSA', loansReg."Loan  No.",
                                                PCharges.Description + ' - ' + loansReg."Client Code" + ' - ' + loansReg."Loan  No.", loansReg."Loan  No.", generalJournal."Application Source"::" ");
                                                //-------------------RECOVER-----------------------------------------------
                                                lineNo := lineNo + 10000;
                                                AuFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                                generalJournal."Account Type"::Vendor, loansReg."Account No", Today, PChargeAmount, 'BOSA', loansReg."Loan  No.",
                                                PCharges.Description + '-' + loansReg."Loan Product Type Name", loansReg."Loan  No.", generalJournal."Application Source"::" ");

                                                //------------------10% EXCISE DUTY----------------------------------------
                                                IF AuFactory.FnChargeExcise(PCharges.Code) THEN BEGIN
                                                    //-------------------Earn--------------------------------- 
                                                    lineNo := lineNo + 10000;
                                                    AuFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                                    generalJournal."Account Type"::"G/L Account", GenSetUp."Excise Duty Account", Today, (PChargeAmount * (GenSetUp."Excise Duty(%)" / 100)) * -1, 'BOSA', loansReg."Loan  No.",
                                                    PCharges.Description + '-' + loansReg."Client Code" + '-' + loansReg."Loan Product Type Name" + '-' + loansReg."Loan  No." + '- Excise Duty', loansReg."Loan  No.", generalJournal."Application Source"::" ");
                                                    //-----------------Recover---------------------------------
                                                    lineNo := lineNo + 10000;
                                                    AuFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                                    generalJournal."Account Type"::Vendor, loansReg."Account No", Today, (PChargeAmount * (GenSetUp."Excise Duty(%)" / 100)), 'BOSA', loansReg."Loan  No.",
                                                    PCharges.Description + '-' + loansReg."Loan Product Type Name" + ' - Excise Duty', loansReg."Loan  No.", generalJournal."Application Source"::" ");
                                                END
                                            //----------------END 10% EXCISE--------------------------------------------
                                            UNTIL PCharges.NEXT = 0;
                                        END;
                                    end;

                                    if (loanProducts."Charge Interest Upfront" <> true) and (loanProducts."Recovery Mode" = loanProducts."Recovery Mode"::Mobile) then begin
                                        InterestAmount := 0;
                                        if loansReg."Repayment Method" = loansReg."repayment method"::Amortised then begin
                                            InterestAmount := ROUND(loansReg."Approved Amount" / 100 / 12 * loanProducts."Interest rate", 1, '>');

                                        end;
                                        if loansReg."Repayment Method" = loansReg."repayment method"::"Reducing Balance" then begin
                                            InterestAmount := ROUND(loansReg."Approved Amount" * loanProducts."Interest rate" / 1200, 1, '>');

                                        end;

                                        if loansReg."Repayment Method" = loansReg."repayment method"::"Straight Line" then begin
                                            InterestAmount := Round((loanProducts."Interest rate" / 12 / 100) * loansReg."Approved Amount", 1, '>');
                                        end;

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Paid",
                                        generalJournal."Account Type"::Customer, loansReg."Client Code", Today, -InterestAmount, '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Upfront' + ' ' + cust."No.", loansReg."Loan  No.");

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Due",
                                        generalJournal."Account Type"::Customer, loansReg."Client Code", Today, InterestAmount, '', docNo,
                                        loanProducts."Product Description" + ' Loan ' + ' ' + cust."No.", loansReg."Loan  No.");

                                    end;
                                    if (loanProducts."Charge Interest Upfront" = true) and (loanProducts."Recover Upfront Interest" = true) then begin
                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                        generalJournal."Account Type"::"G/L Account", loanProducts."Loan Interest Account", Today, ((loansReg.Installments * loanProducts."Interest rate") * Amount / 100) * -1, '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Upfront' + ' ' + cust."No.", '');

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Due",
                                        generalJournal."Account Type"::Customer, loansReg."Client Code", Today, ((loansReg.Installments * loanProducts."Interest rate") * Amount / 100), '', docNo,
                                        loanProducts."Product Description" + ' Loan ' + ' ' + cust."No.", loansReg."Loan  No.");

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                        generalJournal."Account Type"::Vendor, cust."FOSA Account No.", Today, ((loansReg.Installments * loanProducts."Interest rate") * Amount / 100), '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Repayment' + ' ' + loansReg."Loan Product Type Name" + ' ' + cust."No.", '');

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Paid",
                                        generalJournal."Account Type"::Customer, cust."No.", Today, ((loansReg.Installments * loanProducts."Interest rate") * Amount / 100) * -1, '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Repayment' + ' ' + cust."No.", loansReg."Loan  No.");
                                    end;

                                    if (loanProducts."Charge Interest Upfront" = true) and (loanProducts."Recover Upfront Interest" = false) then begin
                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ",
                                        generalJournal."Account Type"::"G/L Account", loanProducts."Loan Interest Account", Today, (loansReg.Installments * loanProducts."Interest rate" * Amount / 100) * -1, '', docNo,
                                        loanProducts."Product Description" + ' Trans interest Upfront' + ' ' + cust."No.", loansReg."Loan  No.");

                                        lineNo := lineNo + 10000;
                                        SFactory.FnCreateGnlJournalLinePaybill(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::"Interest Due",
                                        generalJournal."Account Type"::Customer, loansReg."Client Code", Today, (loansReg.Installments * loanProducts."Interest rate" * Amount / 100), '', docNo,
                                        loanProducts."Product Description" + ' Loan ' + ' ' + cust."No.", loansReg."Loan  No.");
                                    end;

                                    loansReg."Loan Disbursement Date" := Today;
                                    loansReg."Disbursed By Time" := Time;
                                    loansReg."Disbursed By" := UserId;
                                    loansReg.Validate("Loan Disbursement Date");
                                    loansReg."Loan Status" := loansReg."Loan Status"::Issued;
                                    loansReg.Posted := true;
                                    loansReg.Modify;

                                    generalJournal.Reset;
                                    generalJournal.SetRange("Journal Template Name", genTemplate);
                                    generalJournal.SetRange("Journal Batch Name", genBatch);
                                    if generalJournal.FindSet() then begin
                                        Codeunit.Run(Codeunit::"Gen. Jnl.-Post Sacco", generalJournal);
                                    end;

                                    CreationMessage := 'Dear ' + BName.NameStyle(loansReg."Client Code") + ', your ' + loanProducts."Product Description" + ' loan has been disbursed to your FOSA Account.';
                                    smsManagement.SendSmsWithID(Source::LOAN_POSTED, BName.PhoneNo(loansReg."Client Code"), CreationMessage, loansReg."Client Code", loansReg."Account No", TRUE, 200, TRUE, 'CBS', CreateGuid(), 'CBS');

                                    SetResponseStatus(ResponseJson, 'success', 'Success', 'Loan application request has been created successfully');
                                    loanNoJson.Add('application_no', loanNo);
                                end;
                                if loanProducts."Requires Guarantors" or loanProducts."Requires Guarantors Mobile" then begin
                                    guarJson := SelectJsonToken(RequestJson, '$.guarantors').AsArray();
                                    Iterator := guarJson.Count;
                                    Iterator := Iterator - 1;
                                    while (Iterator >= 0) do begin
                                        guarantorNo := SelectJsonToken(RequestJson, '$.guarantors[' + Format(Iterator) + '].member_number').AsValue.AsText;

                                        loanGuarantor.Init();
                                        loanGuarantor."Loan No" := loanNo;
                                        loanGuarantor."Member No" := guarantorNo;

                                        loansGuarantors := loanGuarantor;
                                        recRef.GetTable(loansGuarantors);
                                        fieldVal := recRef.Field(2);

                                        if not FnTestValidate(recRef, fieldVal, 1) then begin
                                            errorMsg := GetLastErrorText + ' - Member No: ' + guarantorNo;
                                            errorFound := true;
                                        end else begin
                                            loanGuarantor.Validate("Member No");
                                            loanGuarantor.Insert;

                                            if member.Get(loanGuarantor."Member No") then begin
                                                CreationMessage := 'Dear ' + member."First Name" + ', you have been selected as a guarantor to ' + cust."First Name" + '''s ' + loansReg."Loan Product Type Name" + '. Kindly use the relevant channels to accept or reject this application.';
                                                smsManagement.SendSmsWithID(Source::LOAN_GUARANTORS, member."Mobile Phone No", CreationMessage, cust."No.", cust."FOSA Account No.", TRUE, 200, TRUE, 'Portal', CreateGuid(), 'Portal');
                                            end;
                                        end;
                                        Iterator := Iterator - 1;
                                    end;
                                    if errorFound then begin
                                        SetResponseStatus(ResponseJson, 'error', 'Error', errorMsg);
                                    end else begin
                                        SetResponseStatus(ResponseJson, 'success', 'Success', 'Loan application request has been created successfully');
                                        loanNoJson.Add('application_no', loanNo);
                                    end;
                                end;
                            end else
                                SetResponseStatus(ResponseJson, 'error', 'Error', 'Loan application failed:- ' + errorMsg);
                        end;
                    end;
                end else
                    SetResponseStatus(ResponseJson, 'error', 'Error', 'Loan product does not exist');
            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'PAYROLL_NO' then begin
            cust.Reset();
            cust.SetRange("Payroll No", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'ID_NO' then begin
            cust.Reset();
            cust.SetRange("ID No.", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'EMAIL' then begin
            cust.Reset();
            cust.SetRange("E-Mail", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;

        ResponseJson.Add(Data, loanNoJson);
        ResponseJson.Add(dateTime, CurrentDateTime);
    end;

    local procedure GetLoanApplicationRequests(RequestJson: JsonObject) ResponseJson: JsonObject
    var
        DataJson: JsonObject;
        IdentifierType: Text;
        Identifier: Text;
        Identifier2: Text;
        Identifier3: Text;
        fileType: Text;
        fileName: Text;
        loanNo: Code[20];
        loanGuarantors: Label 'guarantorship_requests';
        Iterator: Integer;
        loanNoJson: JsonObject;
        loanGuarJson: JsonObject;
        loanGuar: JsonArray;
        LoanApp: JsonArray;
        noSeriesMngt: Codeunit "No. Series";
        cust: Record Customer;
        loansReg: Record "Loans Register";
        loanProducts: Record "Loan Products Setup";
        loanGuarantor: Record "Loans Guarantee Details";
        saccoNoSeries: Record "Sacco No. Series";
    begin
        Iterator := 0;
        IdentifierType := SelectJsonToken(RequestJson, '$.identifier_type').AsValue.AsText;
        Identifier := SelectJsonToken(RequestJson, '$.identifier').AsValue.AsText;

        Identifier2 := InsStr(Identifier, '+', 1);
        Identifier3 := DelChr(Identifier, '<', '254');
        Identifier3 := InsStr(Identifier3, '0', 1);

        saccoNoSeries.Get();
        if IdentifierType = 'MEMBER_NO' then begin
            cust.Reset();
            cust.SetRange("No.", Identifier);
            if cust.FindFirst() then begin
                loansReg.Reset();
                loansReg.SetRange("Client Code", cust."No.");
                loansReg.SetCurrentKey("Application Date");
                loansReg.SetAscending("Application Date", false);
                loansReg.SetFilter("Loan Status", '%1|%2|%3', loansReg."Loan Status"::Application, loansReg."Loan Status"::Appraisal, loansReg."Loan Status"::Approval);
                if loansReg.FindSet() then begin
                    repeat
                        loanProducts.Reset();
                        if loansReg."Loan Product Type" <> '' then begin
                            loanProducts.Get(loansReg."Loan Product Type");
                        end;

                        loanNoJson.Add('application_no', loansReg."Loan  No.");
                        loanNoJson.Add('member_no', loansReg."Client Code");
                        loanNoJson.Add('member_name', loansReg."Client Name");
                        loanNoJson.Add('application_date_time', Format(loansReg.SystemCreatedAt));
                        loanNoJson.Add('loan_product_type', loansReg."Loan Product Type");
                        loanNoJson.Add('loan_product_name', loansReg."Loan Product Type Name");
                        loanNoJson.Add('requested_amount', loansReg."Requested Amount");
                        loanNoJson.Add('eligible_amount', loansReg."Approved Amount");
                        loanNoJson.Add('loan_purpose', loansReg."Sector Specific Name");
                        loanNoJson.Add('installments', loansReg.Installments);
                        loanNoJson.Add('expected_guarantors', loanProducts."Min No. Of Guarantors");
                        loanNoJson.Add('status', Format(loansReg."Loan Status"));

                        loanGuarantor.Reset();
                        loanGuarantor.SetRange("Loan No", loansReg."Loan  No.");
                        if loanGuarantor.FindSet() then begin
                            Iterator := 1;
                            repeat
                                loanGuarJson.Add('entry_no', Iterator);
                                loanGuarJson.Add('member_no', loanGuarantor."Member No");
                                loanGuarJson.Add('member_name', loanGuarantor.Name);
                                loanGuarJson.Add('phone_number', loanGuarantor."Mobile No");
                                loanGuarJson.Add('guarantorship_amount', loanGuarantor."Amont Guaranteed");
                                loanGuarJson.Add('request_status', Format(loanGuarantor."Acceptance Status"));
                                loanGuarJson.Add('request_status_date_time', CreateDateTime(loansReg."Captured By Date", loansReg."Captured By Time"));
                                Iterator += 1;

                                loanGuar.Add(loanGuarJson);
                                clear(loanGuarJson);
                            until loanGuarantor.Next() = 0;
                            loanNoJson.Add('guarantorship_requests', loanGuar);
                            Clear(loanGuar);
                        end;

                        LoanApp.Add(loanNoJson);
                        Clear(loanNoJson);
                    until loansReg.Next() = 0;
                    SetResponseStatus(ResponseJson, 'success', 'Success', 'Loan application request list has been fetched successfully');
                end else
                    SetResponseStatus(ResponseJson, 'success', 'Success', 'No Loans Found');
            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'MSISDN' then begin
            cust.Reset();
