        IdentifierType: Text;
        Identifier: Text;
        Identifier2: Text;
        Identifier3: Text;
        fileType: Text;
        fileName: Text;
        specificSectorJson: JsonObject;
        Iterator: Integer;
        cust: Record Customer;
