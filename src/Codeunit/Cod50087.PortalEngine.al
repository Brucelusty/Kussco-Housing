                    SavLedger.CalcFields(SavLedger.Description);
                    TransactionList.Description := SavLedger.Description;
                    TransactionList.Insert();
                until SavLedger.Next() = 0;
            end;

            // Step 3: Retrieve records in descending order for the requested page
            TransactionList.Reset();
            TransactionList.SetCurrentKey(ID);
            TransactionList.Ascending(false); // Descending order

            if TransactionList.FindSet() then begin
                Count := 0;
                repeat begin
                    Count += 1;
                    if (Count >= FirstRow) and (Count <= LastRow) then begin
                        EntryType := '';
