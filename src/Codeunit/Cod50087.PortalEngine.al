    local procedure ActionLoanGuarantorshipRequest(RequestJson: JsonObject) ResponseJson: JsonObject
    var
        DataJson: JsonObject;
        IdentifierType: Text;
        Identifier: Text;
        loanNo: Text;
        manipulate: Text;
        guarantor: Text;
        guaranteedAmount: Decimal;
        totalGuaranteedAmount: Decimal;
        guarantors: Integer;
        Identifier2: Text;
        Identifier3: Text;
        fileType: Text;
        fileName: Text;
        guarType: Text;
        errorMsg: Text;
        Iterator: Integer;
        loanNoJson: JsonObject;
        loanGuarJson: JsonObject;
        loanGuar: JsonArray;
        LoanApp: JsonArray;
        lineNo: Integer;
        genBatch: Code[20];
        genTemplate: Code[20];
        docNo: Code[20];
        LoanTypeID: Code[20];
        CreationMessage: Text[2500];
        refDate: date;
        InterestAmount: Decimal;
        PChargeAmount: Decimal;
        Amount: Decimal;
        RatingLoanLimit: Decimal;
        loansGuarantors: Variant;
        recRef: RecordRef;
        fieldVal: FieldRef;
        Source: Option NEW_MEMBER,NEW_ACCOUNT,LOAN_ACCOUNT_APPROVAL,DEPOSIT_CONFIRMATION,CASH_WITHDRAWAL_CONFIRM,LOAN_APPLICATION,LOAN_APPRAISAL,LOAN_GUARANTORS,LOAN_REJECTED,LOAN_POSTED,LOAN_DEFAULTED,SALARY_PROCESSING,TELLER_CASH_DEPOSIT,TELLER_CASH_WITHDRAWAL,TELLER_CHEQUE_DEPOSIT,FIXED_DEPOSIT_MATURITY,INTERACCOUNT_TRANSFER,ACCOUNT_STATUS,STATUS_ORDER,EFT_EFFECTED,ATM_APPLICATION_FAILED,ATM_COLLECTION,MBANKING,MEMBER_CHANGES,CASHIER_BELOW_LIMIT,CASHIER_ABOVE_LIMIT,INTERNETBANKING,CRM,MOBILE_PIN,WITHDRAWAL,LOAN_REMINDER,PIGGY_BANK,MEMBER_EXIT,ESS_REFUND,FIXED_DEPOSIT,BOD_HONORARIA,LOAN_RECOVERY,MEMBER_ALLOWANCES,DIVIDEND_PROCESSING;
        noSeriesMngt: Codeunit "No. Series";
        AUFactory: Codeunit "Au Factory";
        SFactory: Codeunit "SURESTEP FactoryMobile";
        mobile: Codeunit "Mobile Banking Engine";
        cust: Record Customer;
        smsManagement: Codeunit "Sms Management";
        loansReg: Record "Loans Register";
        loanProducts: Record "Loan Products Setup";
        loanGuarantor: Record "Loans Guarantee Details";
        loanGuarantorNew: Record "Loans Guarantee Details";
        guarSub: Record "Guarantorship Substitution L";
        saccoNoSeries: Record "Sacco No. Series";
        generalBatch: Record "Gen. Journal Batch";
        generalJournal: Record "Gen. Journal Line";
        GenSetUp: Record "Sacco General Set-Up";
        PCharges: Record "Loan Product Charges";
        CreditRating: Record "Credit Rating";
    begin
        Iterator := 0;

        IdentifierType := SelectJsonToken(RequestJson, '$.identifier_type').AsValue.AsText;
        Identifier := SelectJsonToken(RequestJson, '$.identifier').AsValue.AsText;
        loanNo := SelectJsonToken(RequestJson, '$.application_no').AsValue.AsText;
        manipulate := SelectJsonToken(RequestJson, '$.action').AsValue.AsText;
        guarType := SelectJsonToken(RequestJson, '$.guarantorship_type').AsValue.AsText;

        Identifier2 := InsStr(Identifier, '+', 1);
        Identifier3 := DelChr(Identifier, '<', '254');
        Identifier3 := InsStr(Identifier3, '0', 1);

        genTemplate := 'PAYMENTS';
        genBatch := 'PORTALLOAN';

        saccoNoSeries.Get();
        if IdentifierType = 'MEMBER_NO' then begin
            cust.Reset();
            cust.SetRange("No.", Identifier);
            if cust.FindFirst() then begin
                loansReg.Reset();
                loansReg.SetRange("Loan  No.", loanNo);
                if loansReg.Find('-') then begin
                    loanProducts.Get(loansReg."Loan Product Type");
                    LoanTypeID := loanProducts.Code;
                    loanGuarantor.Reset();
                    loanGuarantor.SetRange("Loan No", loanNo);
                    loanGuarantor.SetRange("Member No", cust."No.");
                    if loanGuarantor.Find('-') then begin
                        if manipulate = 'ACCEPT' then begin
                            guaranteedAmount := SelectJsonToken(RequestJson, '$.accepted_amount').AsValue.AsDecimal;
                            loanGuarantor."Amont Guaranteed" := guaranteedAmount;

                            loansGuarantors := loanGuarantor;
                            recRef.GetTable(loansGuarantors);
                            fieldVal := recRef.Field(11);

                            if not FnTestValidate(recRef, fieldVal, 2) then begin
                                errorMsg := GetLastErrorText;
                                SetResponseStatus(ResponseJson, 'error', 'Error', errorMsg);
                            end else begin

                                loanGuarantor.Validate("Amont Guaranteed");
                                loanGuarantor."Acceptance Status" := loanGuarantor."Acceptance Status"::Accepted;
                                loanGuarantor."Date Accepted" := CurrentDateTime;
                                loanGuarantor."Date Responded" := CurrentDateTime;
                                loanGuarantor.Modify;

                                CreationMessage := 'Dear ' + BName.NameStyle(cust."No.") + ', you have guaranteed ' + BName.NameStyle(loansReg."Client Code") + '''s ' + loanProducts."Product Description" + ' an amount of ' + Format(guaranteedAmount) + '. Thank you for banking with TELEPOST SACCO.';
                                smsManagement.SendSmsWithID(Source::LOAN_GUARANTORS, cust."Mobile Phone No", CreationMessage, cust."No.", cust."FOSA Account No.", TRUE, 200, TRUE, 'CBS', CreateGuid(), 'CBS');

                                CreationMessage := 'Dear ' + BName.NameStyle(loansReg."Client Code") + ', ' + BName.NameStyle(cust."No.") + ' has guaranteed your ' + loanProducts."Product Description" + ' an amount of ' + Format(guaranteedAmount) + '. Thank you for banking with TELEPOST SACCO.';
                                smsManagement.SendSmsWithID(Source::LOAN_GUARANTORS, BName.PhoneNo(loansReg."Client Code"), CreationMessage, loansReg."Client Code", loansReg."Account No", TRUE, 200, TRUE, 'CBS', CreateGuid(), 'CBS');

                                if loanProducts."Is Mobile Loan?" then begin
                                    loanGuarantorNew.Reset();
                                    loanGuarantorNew.SetRange("Loan No", loanNo);
                                    // loanGuarantorNew.SetRange("Member No", cust."No.");
                                    loanGuarantorNew.SetRange("Acceptance Status", loanGuarantorNew."Acceptance Status"::Accepted);
                                    if loanGuarantorNew.FindSet() then begin
                                        guarantors := loanGuarantorNew.Count;
                                        loanGuarantorNew.CalcSums("Amont Guaranteed");
                                        totalGuaranteedAmount := loanGuarantorNew."Amont Guaranteed";

                                        if (guarantors >= loanProducts."Min No. Of Guarantors") and (totalGuaranteedAmount >= loansReg."Requested Amount") then begin
                                            FnPrepJournal(genTemplate, genBatch);
                                            loansReg."Approved Amount" := loansReg."Requested Amount";
                                            loansReg."Recommended Amount" := loansReg."Requested Amount";
                                            loansReg.Modify;

                                            RatingLoanLimit := mobile.GetCreditRatingLimit(cust."No.", loansReg."Loan Product Type");
                                            CreditRating.INIT;
                                            CreditRating."Loan No." := loansReg."Loan  No.";
                                            CreditRating."Document Date" := TODAY;
                                            CreditRating."Loan Amount" := loansReg."Approved Amount";
                                            CreditRating."Date Entered" := TODAY;
                                            CreditRating."Time Entered" := TIME;
                                            CreditRating."Entered By" := USERID;
                                            CreditRating."Account No" := loansReg."Account No";
                                            CreditRating."Member No" := loansReg."Client Code";
                                            CreditRating."Telephone No" := cust."Mobile Phone No";
                                            CreditRating."Customer Name" := loansReg."Client Name";
                                            CreditRating."Loan Product Type" := loansReg."Loan Product Type";
                                            CreditRating."Loan Limit" := RatingLoanLimit;
                                            CreditRating."Staff No." := cust."Payroll No";
                                            CreditRating.INSERT;

                                            docNo := loanNo;
                                            lineNo := lineNo + 10000;
                                            AUFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::Loan, generalJournal."Account Type"::Customer, loansReg."Client Code", Today,
                                            loansReg."Approved Amount", 'BOSA', loanNo, loanProducts."Product Description" + ' - PORTAL', loanNo, generalJournal."Application Source"::Internet);

                                            lineNo := lineNo + 10000;
                                            AUFactory.FnCreateGnlJournalLine(genTemplate, genBatch, docNo, lineNo, generalJournal."Transaction Type"::" ", generalJournal."Account Type"::Vendor, loansReg."Account No", Today,
                                            loansReg."Approved Amount" * -1, 'BOSA', loanNo, loanProducts."Product Description" + ' - PORTAL', loanNo, generalJournal."Application Source"::Internet);

                                            if (LoanTypeID = 'A01') or (LoanTypeID = 'A10') then begin
                                                PCharges.RESET;
                                                PCharges.SETRANGE(PCharges."Product Code", LoanTypeID);
                                                IF PCharges.FIND('-') THEN BEGIN
                                                    REPEAT
                                                        Amount := loansReg."Approved Amount";
