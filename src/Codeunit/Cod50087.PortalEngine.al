    local procedure FnValidateMemberRegistrationInfo(RequestJson: JsonObject) ResponseJson: JsonObject
    var
        DataJson: JsonObject;
        IdentifierType: Text;
        Identifier: Text;
        Identifier2: Text;
        Identifier3: Text;
        firstName: Text;
        middleName: Text;
        uploadedFile: Text;
        nationalitiesJson: JsonObject;
        guarJson: JsonArray;
        Iterator: Integer;
        memberApp: Code[20];
        outStr: OutStream;
        inStr: InStream;
        noSeries: Codeunit "No. Series";
        nationalities: Record "Portal Identification Types";
        saccoNoSeries: Record "Sacco No. Series";
        cust: Record Customer;
        membershipApp: Record "Membership Applications";
        membershipNominees: Record "Member App Nominee";
        TempBlob: CodeUnit "Temp Blob";
        baseX64: CodeUnit "Base64 Convert";
        nationality: JsonArray;
    begin

        saccoNoSeries.Get();
        memberApp := noSeries.GetNextNo(saccoNoSeries."Member Application Nos", 0D, false);
        middleName := SelectJsonToken(RequestJson, '$.primary_identification').AsValue.AsText;
        firstName := SelectJsonToken(RequestJson, '$.transactional_mobile_no').AsValue.AsText;
        Identifier := SelectJsonToken(RequestJson, '$.phone_no').AsValue.AsText;

        Identifier2 := InsStr(Identifier, '+', 1);
        Identifier3 := DelChr(Identifier, '<', '254');
        Identifier3 := InsStr(Identifier3, '0', 1);

        membershipApp.Reset;
        membershipApp.SetRange("ID No.", middleName);
        if membershipApp.Find('-') then begin
            nationalitiesJson.Add('can_apply', 'No');
            SetResponseStatus(ResponseJson, 'success', 'Success', 'Membership application already exists.');
        end else begin
            membershipApp.Reset;
            membershipApp.SetRange("Mobile Phone No", firstName);
            if membershipApp.Find('-') then begin
                nationalitiesJson.Add('can_apply', 'No');
                SetResponseStatus(ResponseJson, 'success', 'Success', 'Membership application already exists.');
            end else begin
                membershipApp.Reset;
                membershipApp.SetFilter("Mobile Phone No", '%1|%2|%3', Identifier, Identifier2, Identifier3);
                if membershipApp.Find('-') then begin
                    nationalitiesJson.Add('can_apply', 'No');
                    SetResponseStatus(ResponseJson, 'success', 'Success', 'Membership application already exists.');
                end else begin
                    cust.Reset;
                    cust.SetRange("ID No.", middleName);
                    if cust.Find('-') then begin
                        nationalitiesJson.Add('can_apply', 'No');
                        SetResponseStatus(ResponseJson, 'success', 'Success', 'Member already exists.');
                    end else begin
                        cust.Reset;
                        cust.SetRange("Mobile Phone No", firstName);
                        if cust.Find('-') then begin
                            nationalitiesJson.Add('can_apply', 'No');
                            SetResponseStatus(ResponseJson, 'success', 'Success', 'Member already exists.');
                        end else begin
                            cust.Reset;
                            cust.SetFilter("Mobile Phone No", '%1|%2|%3', Identifier, Identifier2, Identifier3);
                            if cust.Find('-') then begin
                                nationalitiesJson.Add('can_apply', 'No');
                                SetResponseStatus(ResponseJson, 'success', 'Success', 'Member already exists.');
                            end else begin
                                nationalitiesJson.Add('can_apply', 'Yes');
                                SetResponseStatus(ResponseJson, 'success', 'Success', 'Membership application validated successfully.');
                            end;
                        end;
                    end;
                end;
            end;
        end;

        ResponseJson.Add(Data, nationalitiesJson);
        ResponseJson.Add(dateTime, CurrentDateTime);
    end;

    local procedure FnInitiateMemberRegistration(RequestJson: JsonObject) ResponseJson: JsonObject
    var
        DataJson: JsonObject;
        IdentifierType: Text;
        Identifier: Text;
        firstName: Text;
        middleName: Text;
        lastName: Text;
        countyCode: Text;
        uploadedFile: Text;
        nationalitiesJson: JsonObject;
        guarJson: JsonArray;
        Iterator: Integer;
        memberApp: Code[20];
        outStr: OutStream;
        inStr: InStream;
        noSeries: Codeunit "No. Series";
        nationalities: Record "Portal Identification Types";
        saccoNoSeries: Record "Sacco No. Series";
        membershipApp: Record "Membership Applications";
        membershipNominees: Record "Member App Nominee";
        TempBlob: CodeUnit "Temp Blob";
        baseX64: CodeUnit "Base64 Convert";
        nationality: JsonArray;
    begin

        saccoNoSeries.Get();
        memberApp := noSeries.GetNextNo(saccoNoSeries."Member Application Nos", 0D, false);

        membershipApp.Init();
        membershipApp."First Name" := SelectJsonToken(RequestJson, '$.first_name').AsValue.AsText;
        membershipApp."Middle Name" := SelectJsonToken(RequestJson, '$.middle_name').AsValue.AsText;
        membershipApp."Last Name" := SelectJsonToken(RequestJson, '$.other_names').AsValue.AsText;
        membershipApp.Validate("Last Name");
        membershipApp."Mode of Application" := membershipApp."Mode of Application"::Online;
        membershipApp."Account Category" := membershipApp."Account Category"::Individual;
        membershipApp."ID No." := SelectJsonToken(RequestJson, '$.primary_identification_value').AsValue.AsText;
        membershipApp."Mobile Phone No" := SelectJsonToken(RequestJson, '$.transactional_mobile_no').AsValue.AsText;
        membershipApp."Secondary Mobile No" := SelectJsonToken(RequestJson, '$.office_telephone_no').AsValue.AsText;
        membershipApp."Secondary Mobile No" := SelectJsonToken(RequestJson, '$.phone_no').AsValue.AsText;
        membershipApp."Date of Birth" := SelectJsonToken(RequestJson, '$.date_of_birth').AsValue.AsDate;
        membershipApp.Validate("Date of Birth");

        membershipApp."Home Country" := SelectJsonToken(RequestJson, '$.nationality').AsValue.AsText;
        membershipApp."E-Mail (Personal)" := SelectJsonToken(RequestJson, '$.email_address').AsValue.AsText;
        membershipApp."Workstation County" := SelectJsonToken(RequestJson, '$.current_address').AsValue.AsText;
        membershipApp.Address := SelectJsonToken(RequestJson, '$.permanent_address').AsValue.AsText;
        membershipApp."Postal Code" := SelectJsonToken(RequestJson, '$.post_code').AsValue.AsText;
        membershipApp.City := SelectJsonToken(RequestJson, '$.city').AsValue.AsText;
        membershipApp.County := SelectJsonToken(RequestJson, '$.county').AsValue.AsText;
        membershipApp."Sub-county" := SelectJsonToken(RequestJson, '$.sub_county').AsValue.AsText;
        membershipApp."KRA PIN" := SelectJsonToken(RequestJson, '$.kra_pin_number').AsValue.AsText;
        if SelectJsonToken(RequestJson, '$.is_self_employed').AsValue.AsBoolean then begin
            membershipApp."Employment Info" := membershipApp."Employment Info"::"Self-Employed";
        end else begin
            membershipApp."Employment Info" := membershipApp."Employment Info"::Employed;
            membershipApp."Employer Code" := SelectJsonToken(RequestJson, '$.employer_code').AsValue.AsText;
            membershipApp."Employment Terms" := SelectJsonToken(RequestJson, '$.terms_of_employment').AsValue.AsOption;
        end;
        membershipApp.occupation := SelectJsonToken(RequestJson, '$.occupation').AsValue.AsText;
        membershipApp."Monthly Contribution" := SelectJsonToken(RequestJson, '$.contribution_amount').AsValue.AsInteger;

        nationalities.Reset();
        nationalities.SetRange("Type of Identification", nationalities."Type of Identification"::Salutations);
        nationalities.SetRange(code, SelectJsonToken(RequestJson, '$.salutation').AsValue.AsText);
        if nationalities.Find('-') then begin
            if nationalities.Description = 'Mr' then begin
                membershipApp.Title := membershipApp.Title::"Mr.";
            end else if nationalities.Description = 'Mrs' then begin
                membershipApp.Title := membershipApp.Title::"Mrs.";
            end else if nationalities.Description = 'Miss' then begin
                membershipApp.Title := membershipApp.Title::"Miss.";
            end else if nationalities.Description = 'Dr' then begin
                membershipApp.Title := membershipApp.Title::"DR.";
            end else begin
                membershipApp.Title := membershipApp.Title::" ";
            end;
        end;
        nationalities.Reset();
        nationalities.SetRange("Type of Identification", nationalities."Type of Identification"::Religions);
        nationalities.SetRange(code, SelectJsonToken(RequestJson, '$.religion').AsValue.AsText);
        if nationalities.Find('-') then begin
            if nationalities.Description = 'Islam' then begin
                membershipApp."Religion." := membershipApp."Religion."::Islam;
            end else if nationalities.Description = 'Hinduism' then begin
                membershipApp."Religion." := membershipApp."Religion."::Hinduism;
            end else if nationalities.Description = 'Christianity' then begin
                membershipApp."Religion." := membershipApp."Religion."::Christianity;
            end else if nationalities.Description = 'Buddhism' then begin
                membershipApp."Religion." := membershipApp."Religion."::Buddhism;
            end else if nationalities.Description = 'Atheism' then begin
                membershipApp."Religion." := membershipApp."Religion."::"Religiously Unaffiliated";
            end else begin
                membershipApp."Religion." := membershipApp."Religion."::Others;
            end;
        end;

        uploadedFile := SelectJsonToken(RequestJson, '$.id_front').AsValue.AsText;
        TempBlob.CreateOutStream(outStr, TextEncoding::UTF8);
        baseX64.FromBase64(uploadedFile, outStr);
        TempBlob.CreateInStream(inStr, TextEncoding::UTF8);
        membershipApp."ID Front".ImportStream(inStr, membershipApp.Name + '_Front_ID');

        clear(outStr);
        clear(instr);
        uploadedFile := '';

        uploadedFile := SelectJsonToken(RequestJson, '$.id_back').AsValue.AsText;
        TempBlob.CreateOutStream(outStr, TextEncoding::UTF8);
