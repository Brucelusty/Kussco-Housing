    local procedure GetMemberSelfLoanAppraisalRequest(RequestJson: JsonObject) ResponseJson: JsonObject
    var
        DataJson: JsonObject;
        IdentifierType: Text;
        Identifier: Text;
        loanType: Text;
        loanInst: Integer;
        i: Integer;
        otherIncome: Decimal;
        requestedAmount: Decimal;
        basicSalAmount: Decimal;
        totalEarnings: Decimal;
        totalDeductions: Decimal;
        totalDeduction: Decimal;
        thirdBasic: Decimal;
        twoThirdsBasic: Decimal;
        utilizableAmount: Decimal;
        repayment: Decimal;
        Psalary: Decimal;
        Pdeposits: Decimal;
        FirstAmount: Decimal;
        SecondAmount: Decimal;
        eligibleAmount: Decimal;
        PChargeAmount: Decimal;
        PChargeExcise: Decimal;
        PChargeTotal: Decimal;
        LoanAmount: Decimal;
        InterestRate: Decimal;
        RepayPeriod: Integer;
        InitialInstal: Decimal;
        LBalance: Decimal;
        RunDate: Date;
        InstalNo: Decimal;
        TotalMRepay: Decimal;
        LInterest: Decimal;
        LPrincipal: Decimal;
        appraisalAmount: Decimal;
        salProc: Decimal;
        totalCredit: Decimal;
        totalDebit: Decimal;
        offsets: Decimal;
        MaxLoan: Decimal;
        hasTopUp: Boolean;
        hasOtherIncome: Boolean;
        GrPrinciple: Integer;
        Installments: Integer;
        topUp: Text;//To be rectified to align with an array data type
        Identifier2: Text;
        Identifier3: Text;
        fileType: Text;
        fileName: Text;
        LoanProduct: Text;
        recoveryMode: Text;
        Iterator: Integer;
        loanNoJson: JsonObject;
        loanRepayJson: JsonObject;
        loanRepay: JsonArray;
        LoanApp: JsonArray;
        topups: JsonArray;
        noSeriesMngt: Codeunit "No. Series";
        mobileEngine: CodeUnit "Mobile Banking Engine";
        cust: Record Customer;
        loansReg: Record "Loans Register";
        loanProducts: Record "Loan Products Setup";
        loanRepayTemp: Record "Loan Repayment Schedule";
        loanGuarantor: Record "Loans Guarantee Details";
        saccoNoSeries: Record "Sacco No. Series";
        PCharges: Record "Loan Product Charges";
        GenSetUp: Record "Sacco General Set-Up";
    begin
        Iterator := 0;
        appraisalAmount := 0;
        salProc := 0;
        totalCredit := 0;
        totalDebit := 0;
        totalDebit := 0;

        IdentifierType := SelectJsonToken(RequestJson, '$.identifier_type').AsValue.AsText;
        Identifier := SelectJsonToken(RequestJson, '$.identifier').AsValue.AsText;
        loanType := SelectJsonToken(RequestJson, '$.loan_product').AsValue.AsText;
        requestedAmount := SelectJsonToken(RequestJson, '$.requested_amount').AsValue.AsDecimal;
        basicSalAmount := SelectJsonToken(RequestJson, '$.basic_salary').AsValue.AsDecimal;
        totalEarnings := SelectJsonToken(RequestJson, '$.total_earnings').AsValue.AsDecimal;
        totalDeductions := SelectJsonToken(RequestJson, '$.total_deductions').AsValue.AsDecimal;
        loanInst := SelectJsonToken(RequestJson, '$.requested_amount').AsValue.AsDecimal;
        Installments := SelectJsonToken(RequestJson, '$.installments').AsValue.AsInteger;
        recoveryMode := SelectJsonToken(RequestJson, '$.recovery_mode').AsValue.AsText;
        if loanType <> 'A03' then begin
            hasTopUp := SelectJsonToken(RequestJson, '$.has_loan_topup').AsValue.AsBoolean;
            hasOtherIncome := SelectJsonToken(RequestJson, '$.has_other_income').AsValue.AsBoolean;

            if hasOtherIncome then begin
                otherIncome := SelectJsonToken(RequestJson, '$.other_income').AsValue.AsDecimal;
            end;

            offsets := 0;
            if hasTopUp then begin
                topUps := SelectJsonToken(RequestJson, '$.top_ups').AsArray;
                iterator := topUps.Count;
                iterator := iterator - 1;
                while iterator >= 0 do begin
                    topUp := SelectJsonToken(RequestJson, '$.top_ups[' + Format(iterator) + ']').AsValue.AsText;
                    offsets := offsets + FnFetchOffsetDeductions(cust."No.", topUp);
                    iterator := iterator - 1;
                end;
            end;
        end;

        Identifier2 := InsStr(Identifier, '+', 1);
        Identifier3 := DelChr(Identifier, '<', '254');
        Identifier3 := InsStr(Identifier3, '0', 1);

        saccoNoSeries.Get();
        if IdentifierType = 'MEMBER_NO' then begin
            cust.Reset();
            cust.SetRange("No.", Identifier);
            if cust.FindFirst() then begin

                if cust."Employer Code" = 'STAFF' then begin
                    recoveryMode := 'Checkoff';
                end else
                    recoveryMode := 'Salary';

                cust.CalcFields("Current Shares", "Total Loan Balance", "Wezesha Savings", "Jibambe Savings", "School Fees Shares", "Fixed Deposit", "Mdosi Junior", "Pension Akiba");
                loanProducts.Reset();
                loanProducts.SetRange(Code, loanType);
                if loanProducts.Find('-') then begin

                    case recoveryMode of
                        'Checkoff':
                            begin
                                if cust."Employer Code" = 'TELKOM' then begin
                                    thirdBasic := Round(((basicSalAmount + totalEarnings) / 3), 0.01, '=');
                                    salProc := 0;

                                    twoThirdsBasic := basicSalAmount - thirdBasic;
                                    totalCredit := twoThirdsBasic + otherIncome + totalEarnings + offsets;
                                    totalDebit := salProc + totalDeductions;
                                    utilizableAmount := (totalCredit - totalDebit);
                                end else begin
                                    thirdBasic := Round((basicSalAmount / 3), 0.01, '=');
                                    salProc := 0;

                                    twoThirdsBasic := basicSalAmount - thirdBasic;
                                    totalCredit := twoThirdsBasic + otherIncome + totalEarnings + offsets;
                                    totalDebit := salProc + totalDeductions;
                                    utilizableAmount := (totalCredit - totalDebit);
                                end;
                            end;
                        'Salary':
                            begin
                                appraisalAmount := Round(((100 - loanProducts."Loan Appraisal %") / 100), 0.01, '<');
                                thirdBasic := Round((basicSalAmount * appraisalAmount), 0.01, '=');
                                salProc := 144;

                                if cust."Employer Code" = 'STAFF' then begin

                                    twoThirdsBasic := basicSalAmount - thirdBasic;
                                    totalCredit := basicSalAmount + otherIncome + totalEarnings + offsets;
                                    totalDebit := salProc + totalDeductions;
                                    utilizableAmount := Round(((totalCredit - totalDebit) * (loanProducts."Loan Appraisal %" / 100)), 0.01, '<');
                                end else begin

                                    twoThirdsBasic := basicSalAmount - thirdBasic;
                                    totalDeduction := FnFetchSTODeductions(cust."No.") + FnFetchLoanDeductions(cust."No.");
                                    totalCredit := twoThirdsBasic + otherIncome + totalEarnings + offsets;
                                    totalDebit := salProc + totalDeductions;
                                    utilizableAmount := Round(((totalCredit - totalDebit) * (loanProducts."Loan Appraisal %" / 100)), 0.01, '<');
                                end;
                            end;
                    end;

                    if loanProducts."Exempt Interest" = false then begin
                        FirstAmount := 1 - (1 / POWER((1 + (loanProducts."Interest rate" / 12 / 100)), loanProducts."Default Installements"));
                        SecondAmount := ROUND(utilizableAmount / (loanProducts."Interest rate" / 12 / 100));
                        Psalary := FirstAmount * SecondAmount;
                    end else begin
                        Psalary := utilizableAmount;
                    end;

                    if loanProducts."ESS Account" then begin
                        Pdeposits := cust."School Fees Shares";
                    end else if loanProducts."Wezesha Account" then begin
                        Pdeposits := cust."Wezesha Savings";
                    end else if loanProducts."Jibambe Account" then begin
                        Pdeposits := cust."Jibambe Savings";
                    end else if loanProducts."MdosiJr Account" then begin
                        Pdeposits := cust."Mdosi Junior";
                    end else if loanProducts."FD Account" then begin
                        Pdeposits := cust."Fixed Deposit";
                    end else begin
                        Pdeposits := cust."Current Shares";
                    end;

                    if loanProducts."Deposits Multiplier" <= 0 then begin
                        Pdeposits := Pdeposits;
                    end else
                        Pdeposits := (Pdeposits) * loanProducts."Deposits Multiplier";

                    if (loanType = 'A03') or (loanType = 'A16') then begin
                        eligibleAmount := mobileEngine.FnGetMobileAdvanceEligibility(cust."FOSA Account No.", loanType, loanProduct, loanProducts."Max. Loan Amount", Installments);
                    end;
                    if loanType = 'A01' then begin
                        eligibleAmount := mobileEngine.GetSalaryLoanQualifiedAmount(cust."FOSA Account No.", loanType, loanProducts."Max. Loan Amount", loanProduct, Installments)
                    end;
                    if loanType = 'M_OD' then begin
                        eligibleAmount := mobileEngine.GetOverdraftLoanQualifiedAmount(cust."FOSA Account No.", loanType, loanProducts."Max. Loan Amount", loanProduct)
                    end;
                    if loanType = 'A10' then begin
                        eligibleAmount := mobileEngine.GetReloadedLoanQualifiedAmount(cust."FOSA Account No.", loanType, loanProducts."Max. Loan Amount", loanProduct, Installments)
                    end;
                    if loanProducts."Is Mobile Loan?" = false then begin
                        eligibleAmount := Round(FnReccommendAmount(loanType, requestedAmount, Pdeposits, requestedAmount, Psalary, Pdeposits), 0.01, '=');
                    end;

                    if loanProducts."Repayment Method" = loanProducts."repayment method"::Amortised then begin
                        repayment := ROUND((loanProducts."Interest rate" / 12 / 100) / (1 - Power((1 + (loanProducts."Interest rate" / 12 / 100)), -(Installments))) * (requestedAmount), 0.01, '>');
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::"Reducing Balance" then begin
                        if Installments > 12 then begin
                            repayment := ROUND(requestedAmount * loanProducts."Interest rate" / 1200, 1, '>') + Round((requestedAmount / Installments), 0.01, '=');
                        end else
                            repayment := ROUND(requestedAmount * loanProducts."Interest rate" / Installments / 100, 1, '>') + Round((requestedAmount / Installments), 0.01, '=');
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::"Straight Line" then begin
                        if loanType = 'A03' then begin
                            repayment := Round(loanProducts."Interest rate" / 100) * requestedAmount + Round((requestedAmount / Installments), 0.01, '=');
                        end else begin
                            repayment := Round(loanProducts."Interest rate" / 12 / 100) * requestedAmount + Round((requestedAmount / Installments), 0.01, '=');
                        end;
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::Constants then begin
                        repayment := Round(requestedAmount / Installments);
                    end;


                    PCharges.RESET;
                    PCharges.SETRANGE("Product Code", loanType);
                    IF PCharges.FIND('-') THEN BEGIN
                        REPEAT
                            PChargeAmount := PCharges.Amount;
                            IF PCharges."Use Perc" = TRUE THEN begin
                                PChargeAmount := (requestedAmount * PCharges.Percentage / 100);
                                GenSetUp.Get();
                                PChargeExcise := PChargeAmount * (GenSetUp."Excise Duty(%)" / 100);
                                PChargeTotal := PChargeAmount + PChargeExcise;
                            end;
                        UNTIL PCharges.NEXT = 0;
                    END;

                    totalDeduction := totalDeductions;
                    loanNoJson.Add('member_no', cust."No.");
                    loanNoJson.Add('member_name', cust.Name);
                    loanNoJson.Add('loan_product', loanProducts.Code);
                    loanNoJson.Add('loan_product_name', loanProducts."Product Description");
                    loanNoJson.Add('requested_amount', requestedAmount);
                    loanNoJson.Add('eligible_amount', eligibleAmount);
                    loanNoJson.Add('monthly_repayment', repayment);
                    loanNoJson.Add('loan_repayments', FnFetchLoanDeductions(cust."No."));
                    loanNoJson.Add('total_deductions', totalDeduction);
                    loanNoJson.Add('interest_rate', loanProducts."Interest rate");
                    loanNoJson.Add('interest_rate_monthly', loanProducts."Interest rate" / 12);
                    loanNoJson.Add('interest_calculation_method', Format(loanProducts."repayment method"));
                    loanNoJson.Add('intsallments', Installments);
                    loanNoJson.Add('max_installments', loanProducts."Default Installements");
                    loanNoJson.Add('total_charges', PChargeTotal);
                    loanNoJson.Add('total_top_up', offsets);
                    loanNoJson.Add('net_income', utilizableAmount);
                    loanNoJson.Add('third_of_basic', twoThirdsBasic);
                    loanNoJson.Add('salary_qualification', Psalary);
                    loanNoJson.Add('deposit_qualification', Pdeposits);
                    loanNoJson.Add('take_home', requestedAmount - offsets - PChargeTotal);
                    loanNoJson.Add('bosa_loans_balance', cust."Total Loan Balance");

                    LoanAmount := eligibleAmount;
                    InterestRate := loanProducts."Interest rate";
                    RepayPeriod := Installments;
                    InitialInstal := loanProducts."Default Installements";
                    LBalance := eligibleAmount;
                    RunDate := Today;
                    InstalNo := 0;

                    repeat
                        InstalNo := InstalNo + 1;
                        if loanProducts."Repayment Frequency" = loanProducts."repayment frequency"::Daily then
                            RunDate := CalcDate('1D', RunDate)
                        else if loanProducts."Repayment Frequency" = loanProducts."repayment frequency"::Weekly then
                            RunDate := CalcDate('1W', RunDate)
                        else if loanProducts."Repayment Frequency" = loanProducts."repayment frequency"::Monthly then
                            RunDate := CalcDate('1M', RunDate)
                        else if loanProducts."Repayment Frequency" = loanProducts."repayment frequency"::Quaterly then
                            RunDate := CalcDate('1Q', RunDate);

                        if loanProducts."Repayment Method" = loanProducts."repayment method"::Amortised then begin
                            TotalMRepay := ROUND((InterestRate / 12 / 100) / (1 - POWER((1 + (InterestRate / 12 / 100)), -(RepayPeriod))) * (LoanAmount), 0.05, '>');
                            LInterest := ROUND(LBalance / 100 / 12 * InterestRate, 0.05, '>');
                            LPrincipal := TotalMRepay - LInterest;
                        end;
                        if loanProducts."Repayment Method" = loanProducts."repayment method"::"Straight Line" then begin
                            if loanType = 'A03' then begin
                                LPrincipal := LoanAmount / RepayPeriod;
                                LInterest := (InterestRate / 100) * LoanAmount;
                            end else begin
                                LPrincipal := LoanAmount / RepayPeriod;
                                LInterest := (InterestRate / 12 / 100) * LoanAmount;
                            end;
                        end;
                        if loanProducts."Repayment Method" = loanProducts."repayment method"::"Reducing Balance" then begin
                            LPrincipal := LoanAmount / RepayPeriod;
                            LInterest := ROUND(LBalance * InterestRate / 1200, 1, '>');
                        end;
                        if loanProducts."Repayment Method" = loanProducts."repayment method"::Constants then begin
                            if LBalance < Repayment then
                                LPrincipal := LBalance else begin
                                LPrincipal := Repayment;
                                LInterest := (InterestRate / 12 / 100) * LoanAmount;
                            end;
                        end;

                        LBalance := LBalance - LPrincipal;

                        loanRepayJson.Add('installment_no', InstalNo);
                        loanRepayJson.Add('repayment_date', CalcDate('CM', RunDate));
                        loanRepayJson.Add('loan_product', loanProducts."Product Description");
                        loanRepayJson.Add('monthly_repayment', LInterest + LPrincipal);
                        loanRepayJson.Add('monthly_interest', LInterest);
                        loanRepayJson.Add('monthly_principal', LPrincipal);
                        loanRepayJson.Add('loan_balance', LBalance);

                        loanRepay.Add(loanRepayJson);
                        Clear(loanRepayJson);
                    until LBalance < 1;

                    loanNoJson.Add('repayment_schedule', loanRepay);
                    SetResponseStatus(ResponseJson, 'success', 'Success', 'Self-Loan Appraisal request successful.');

                end else
                    SetResponseStatus(ResponseJson, 'error', 'Error', 'Loan Product does not exist');
            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'MSISDN' then begin
            cust.Reset();
            cust.SetFilter("Mobile Phone No", '%1|%2|%3', Identifier, Identifier2, Identifier3);
            if cust.FindFirst() then begin

                if cust."Employer Code" = 'STAFF' then begin
                    recoveryMode := 'Checkoff';
                end else
                    recoveryMode := 'Salary';

                cust.CalcFields("Current Shares", "Total Loan Balance", "Wezesha Savings", "Jibambe Savings", "School Fees Shares", "Fixed Deposit", "Mdosi Junior", "Pension Akiba");
                loanProducts.Reset();
                loanProducts.SetRange(Code, loanType);
                if loanProducts.Find('-') then begin
                    case recoveryMode of
                        'Checkoff':
                            begin
                                if cust."Employer Code" = 'TELKOM' then begin
                                    thirdBasic := Round(((basicSalAmount + totalEarnings) / 3), 0.01, '=');
                                    salProc := 0;

                                    twoThirdsBasic := basicSalAmount - thirdBasic;
                                    totalCredit := twoThirdsBasic + otherIncome + totalEarnings + offsets;
                                    totalDebit := salProc + totalDeductions;
                                    utilizableAmount := (totalCredit - totalDebit);
                                end else begin
                                    thirdBasic := Round((basicSalAmount / 3), 0.01, '=');
                                    salProc := 0;

                                    twoThirdsBasic := basicSalAmount - thirdBasic;
                                    totalCredit := twoThirdsBasic + otherIncome + totalEarnings + offsets;
                                    totalDebit := salProc + totalDeductions;
                                    utilizableAmount := (totalCredit - totalDebit);
                                end;
                            end;
                        'Salary':
                            begin
                                appraisalAmount := Round(((100 - loanProducts."Loan Appraisal %") / 100), 0.01, '<');
                                thirdBasic := Round((basicSalAmount * appraisalAmount), 0.01, '=');

                                if cust."Employer Code" = 'STAFF' then begin

                                    salProc := 0;
                                    twoThirdsBasic := basicSalAmount - thirdBasic;
                                    totalCredit := basicSalAmount + otherIncome + totalEarnings + offsets;
                                    totalDebit := salProc + totalDeductions;
                                    utilizableAmount := Round(((totalCredit - totalDebit) * (loanProducts."Loan Appraisal %" / 100)), 0.01, '<');
                                end else begin

                                    salProc := 144;
                                    twoThirdsBasic := basicSalAmount - thirdBasic;
                                    totalDeduction := FnFetchSTODeductions(cust."No.") + FnFetchLoanDeductions(cust."No.");
                                    totalCredit := twoThirdsBasic + otherIncome + totalEarnings + offsets;
                                    totalDebit := salProc + totalDeductions;
                                    utilizableAmount := Round(((totalCredit - totalDebit) * (loanProducts."Loan Appraisal %" / 100)), 0.01, '<');
                                end;
                            end;
                    end;

                    if loanProducts."Exempt Interest" = false then begin
                        FirstAmount := 1 - (1 / POWER((1 + (loanProducts."Interest rate" / 12 / 100)), loanProducts."Default Installements"));
                        SecondAmount := ROUND(utilizableAmount / (loanProducts."Interest rate" / 12 / 100));
                        Psalary := FirstAmount * SecondAmount;
                    end else begin
                        Psalary := utilizableAmount;
                    end;

                    if loanProducts."ESS Account" then begin
                        Pdeposits := cust."School Fees Shares";
                    end else if loanProducts."Wezesha Account" then begin
                        Pdeposits := cust."Wezesha Savings";
                    end else if loanProducts."Jibambe Account" then begin
                        Pdeposits := cust."Jibambe Savings";
                    end else if loanProducts."MdosiJr Account" then begin
                        Pdeposits := cust."Mdosi Junior";
                    end else if loanProducts."FD Account" then begin
                        Pdeposits := cust."Fixed Deposit";
                    end else begin
                        Pdeposits := cust."Current Shares";
                    end;

                    if loanProducts."Deposits Multiplier" <= 0 then begin
                        Pdeposits := Pdeposits;
                    end else
                        Pdeposits := (Pdeposits) * loanProducts."Deposits Multiplier";

                    if (loanType = 'A03') or (loanType = 'A16') then begin
                        eligibleAmount := mobileEngine.FnGetMobileAdvanceEligibility(cust."FOSA Account No.", loanType, loanProduct, loanProducts."Max. Loan Amount", Installments);
                    end;
                    if loanType = 'A01' then begin
                        eligibleAmount := mobileEngine.GetSalaryLoanQualifiedAmount(cust."FOSA Account No.", loanType, loanProducts."Max. Loan Amount", loanProduct, Installments)
                    end;
                    if loanType = 'M_OD' then begin
                        eligibleAmount := mobileEngine.GetOverdraftLoanQualifiedAmount(cust."FOSA Account No.", loanType, loanProducts."Max. Loan Amount", loanProduct)
                    end;
                    if loanType = 'A10' then begin
                        eligibleAmount := mobileEngine.GetReloadedLoanQualifiedAmount(cust."FOSA Account No.", loanType, loanProducts."Max. Loan Amount", loanProduct, Installments)
                    end;
                    if loanProducts."Is Mobile Loan?" = false then begin
                        eligibleAmount := Round(FnReccommendAmount(loanType, requestedAmount, Pdeposits, requestedAmount, Psalary, Pdeposits), 0.01, '=');
                    end;

                    if loanProducts."Repayment Method" = loanProducts."repayment method"::Amortised then begin
                        repayment := ROUND((loanProducts."Interest rate" / 12 / 100) / (1 - Power((1 + (loanProducts."Interest rate" / 12 / 100)), -(Installments))) * (requestedAmount), 0.01, '>');
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::"Reducing Balance" then begin
                        if Installments > 12 then begin
                            repayment := ROUND(requestedAmount * loanProducts."Interest rate" / 1200, 1, '>') + Round((requestedAmount / Installments), 0.01, '=');
                        end else
                            repayment := ROUND(requestedAmount * loanProducts."Interest rate" / Installments / 100, 1, '>') + Round((requestedAmount / Installments), 0.01, '=');
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::"Straight Line" then begin
                        if loanType = 'A03' then begin
                            repayment := Round(loanProducts."Interest rate" / 100) * requestedAmount + Round((requestedAmount / Installments), 0.01, '=');
                        end else begin
                            repayment := Round(loanProducts."Interest rate" / 12 / 100) * requestedAmount + Round((requestedAmount / Installments), 0.01, '=');
                        end;
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::Constants then begin
                        repayment := Round(requestedAmount / Installments);
                    end;

                    PCharges.RESET;
                    PCharges.SETRANGE("Product Code", loanType);
                    IF PCharges.FIND('-') THEN BEGIN
                        REPEAT
                            PChargeAmount := PCharges.Amount;
                            IF PCharges."Use Perc" = TRUE THEN begin
                                PChargeAmount := (requestedAmount * PCharges.Percentage / 100);
                                GenSetUp.Get();
                                PChargeExcise := PChargeAmount * (GenSetUp."Excise Duty(%)" / 100);
                                PChargeTotal := PChargeAmount + PChargeExcise;
                            end;
                        UNTIL PCharges.NEXT = 0;
                    END;

                    totalDeduction := totalDeductions;
                    loanNoJson.Add('member_no', cust."No.");
                    loanNoJson.Add('member_name', cust.Name);
                    loanNoJson.Add('loan_product', loanProducts.Code);
                    loanNoJson.Add('loan_product_name', loanProducts."Product Description");
                    loanNoJson.Add('requested_amount', requestedAmount);
                    loanNoJson.Add('eligible_amount', eligibleAmount);
                    loanNoJson.Add('monthly_repayment', repayment);
                    loanNoJson.Add('loan_repayments', FnFetchLoanDeductions(cust."No."));
                    loanNoJson.Add('total_deductions', totalDeduction);
                    loanNoJson.Add('interest_rate', loanProducts."Interest rate");
                    loanNoJson.Add('interest_rate_monthly', loanProducts."Interest rate" / 12);
                    loanNoJson.Add('interest_calculation_method', Format(loanProducts."repayment method"));
                    loanNoJson.Add('intsallments', Installments);
                    loanNoJson.Add('max_installments', loanProducts."Default Installements");
                    loanNoJson.Add('total_charges', PChargeTotal);
                    loanNoJson.Add('total_top_up', offsets);
                    loanNoJson.Add('net_income', utilizableAmount);
                    loanNoJson.Add('third_of_basic', twoThirdsBasic);
                    loanNoJson.Add('salary_qualification', Psalary);
                    loanNoJson.Add('deposit_qualification', Pdeposits);
                    loanNoJson.Add('take_home', requestedAmount - offsets - PChargeTotal);
                    loanNoJson.Add('bosa_loans_balance', cust."Total Loan Balance");

                    LoanAmount := eligibleAmount;
                    InterestRate := loanProducts."Interest rate";
                    RepayPeriod := Installments;
                    InitialInstal := loanProducts."Default Installements";
                    LBalance := eligibleAmount;
                    RunDate := Today;
                    InstalNo := 0;

                    repeat
                        InstalNo := InstalNo + 1;
                        if loanProducts."Repayment Frequency" = loanProducts."repayment frequency"::Daily then
                            RunDate := CalcDate('1D', RunDate)
                        else if loanProducts."Repayment Frequency" = loanProducts."repayment frequency"::Weekly then
                            RunDate := CalcDate('1W', RunDate)
                        else if loanProducts."Repayment Frequency" = loanProducts."repayment frequency"::Monthly then
                            RunDate := CalcDate('1M', RunDate)
                        else if loanProducts."Repayment Frequency" = loanProducts."repayment frequency"::Quaterly then
                            RunDate := CalcDate('1Q', RunDate);

                        if loanProducts."Repayment Method" = loanProducts."repayment method"::Amortised then begin
                            TotalMRepay := ROUND((InterestRate / 12 / 100) / (1 - POWER((1 + (InterestRate / 12 / 100)), -(RepayPeriod))) * (LoanAmount), 0.05, '>');
                            LInterest := ROUND(LBalance / 100 / 12 * InterestRate, 0.05, '>');
                            LPrincipal := TotalMRepay - LInterest;
                        end;
                        if loanProducts."Repayment Method" = loanProducts."repayment method"::"Straight Line" then begin
                            if loanType = 'A03' then begin
                                LPrincipal := LoanAmount / RepayPeriod;
                                LInterest := (InterestRate / 100) * LoanAmount;
                            end else begin
                                LPrincipal := LoanAmount / RepayPeriod;
                                LInterest := (InterestRate / 12 / 100) * LoanAmount;
                            end;
                        end;
                        if loanProducts."Repayment Method" = loanProducts."repayment method"::"Reducing Balance" then begin
                            LPrincipal := LoanAmount / RepayPeriod;
                            LInterest := ROUND(LBalance * InterestRate / 1200, 1, '>');
                        end;
                        if loanProducts."Repayment Method" = loanProducts."repayment method"::Constants then begin
                            if LBalance < Repayment then
                                LPrincipal := LBalance else begin
                                LPrincipal := Repayment;
                                LInterest := (InterestRate / 12 / 100) * LoanAmount;
                            end;
                        end;

                        LBalance := LBalance - LPrincipal;

                        loanRepayJson.Add('installment_no', InstalNo);
                        loanRepayJson.Add('repayment_date', CalcDate('CM', RunDate));
                        loanRepayJson.Add('loan_product', loanProducts."Product Description");
                        loanRepayJson.Add('monthly_repayment', LInterest + LPrincipal);
                        loanRepayJson.Add('monthly_interest', LInterest);
                        loanRepayJson.Add('monthly_principal', LPrincipal);
                        loanRepayJson.Add('loan_balance', LBalance);

                        loanRepay.Add(loanRepayJson);
                        Clear(loanRepayJson);
                    until LBalance < 1;

                    loanNoJson.Add('repayment_schedule', loanRepay);
                    SetResponseStatus(ResponseJson, 'success', 'Success', 'Self-Loan Appraisal request successful.');
                end else
                    SetResponseStatus(ResponseJson, 'error', 'Error', 'Loan Product does not exist');
            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'PAYROLL_NO' then begin
            cust.Reset();
            cust.SetRange("Payroll No", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'ID_NO' then begin
            cust.Reset();
            cust.SetRange("ID No.", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;
        if IdentifierType = 'EMAIL' then begin
            cust.Reset();
            cust.SetRange("E-Mail", Identifier);
            if cust.FindFirst() then begin


            end else
                SetResponseStatus(ResponseJson, 'error', 'Error', 'Member does not exist');
        end;

        ResponseJson.Add(Data, loanNoJson);
        ResponseJson.Add(dateTime, CurrentDateTime);
    end;

    local procedure FnGetMemberLoanEligibility(memberNo: Code[20]; loanProduct: Code[20]) eligible: Decimal
    var
        myInt: Integer;
        loanInst: Integer;
        i: Integer;
        otherIncome: Decimal;
        requestedAmount: Decimal;
        basicSalAmount: Decimal;
        totalEarnings: Decimal;
        totalDeductions: Decimal;
        totalDeduction: Decimal;
        thirdBasic: Decimal;
        twoThirdsBasic: Decimal;
        utilizableAmount: Decimal;
        repayment: Decimal;
        Psalary: Decimal;
        Pdeposits: Decimal;
        FirstAmount: Decimal;
        SecondAmount: Decimal;
        eligibleAmount: Decimal;
        LoanAmount: Decimal;
        InterestRate: Decimal;
        RepayPeriod: Integer;
        InitialInstal: Decimal;
        LBalance: Decimal;
        RunDate: Date;
        InstalNo: Decimal;
        cust: Record Customer;
        salDetails: Record "Salary Details";
        payroll: Record "prPeriod Transactions.";
        loansReg: Record "Loans Register";
        loanProducts: Record "Loan Products Setup";
        loanRepayTemp: Record "Loan Repayment Schedule";
        loanGuarantor: Record "Loans Guarantee Details";
    begin
        cust.Reset();
        cust.SetRange("No.", memberNo);
        if cust.FindFirst() then begin
            cust.CalcFields("Current Shares", "Total Loan Balance");
            loanProducts.Reset();
            loanProducts.SetRange(Code, loanProduct);
            if loanProducts.Find('-') then begin

                if cust."Employer Code" = 'STAFF' then begin
                    payroll.Reset();
                    payroll.SetRange("Employee Code", cust."Payroll No");
                    payroll.SetRange("Group Text", 'BASIC PAY');
                    payroll.SetCurrentKey("Payroll Period");
                    payroll.SetAscending("Payroll Period", true);
                    if payroll.FindLast() then begin
                        basicSalAmount := payroll.Amount;
                    end;
                end else begin
                    salDetails.Reset();
                    salDetails.SetRange("Member No", cust."No.");
                    salDetails.SetRange("Salary Type", salDetails."Salary Type"::Salary);
                    if salDetails.FindLast() then begin
                        basicSalAmount := salDetails."Gross Amount";
                    end;
                end;

                twoThirdsBasic := Round((basicSalAmount * (loanProducts."Loan Appraisal %" / 100)), 0.01, '=');
                // totalEarnings := FnFetchLoanOffset()
                // Check on how to go about this - loan offsets
                totalDeduction := FnFetchSTODeductions(cust."No.") + FnFetchLoanDeductions(cust."No.");
                utilizableAmount := ((twoThirdsBasic + 0) - (totalDeduction + 144));

                if loanProducts."Exempt Interest" = false then begin
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::Amortised then begin
                        repayment := ROUND((loanProducts."Interest rate" / 12 / 100) / (1 - Power((1 + (loanProducts."Interest rate" / 12 / 100)), -(loanProducts."Default Installements"))) * (requestedAmount), 0.0001, '>');
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::"Reducing Balance" then begin
                        if loanProducts."Default Installements" > 12 then begin
                            repayment := ROUND(requestedAmount * loanProducts."Interest rate" / 1200, 1, '>') + Round((requestedAmount / loanProducts."Default Installements"), 0.01, '=');
                        end else
                            repayment := ROUND(requestedAmount * loanProducts."Interest rate" / loanProducts."Default Installements" / 100, 1, '>') + Round((requestedAmount / loanProducts."Default Installements"), 0.01, '=');
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::"Reducing Balance" then begin
                        repayment := Round(loanProducts."Interest rate" / 12 / 100) * requestedAmount / loanProducts."Default Installements" + Round((requestedAmount / loanProducts."Default Installements"), 0.01, '=');
                    end;
                    if loanProducts."Repayment Method" = loanProducts."repayment method"::Constants then begin
                        repayment := Round(requestedAmount / loanProducts."Default Installements");
                    end;

                    FirstAmount := 1 - (1 / POWER((1 + (loanProducts."Interest rate" / 12 / 100)), loanProducts."Default Installements"));
                    SecondAmount := ROUND(utilizableAmount / (loanProducts."Interest rate" / 12 / 100));
                    Psalary := FirstAmount * SecondAmount;
                end else begin
                    repayment := Round((requestedAmount / loanProducts."Default Installements"), 0.01, '<');
                    Psalary := utilizableAmount;
                end;

                if loanProducts."ESS Account" then begin
                    Pdeposits := cust."School Fees Shares";
                end else begin
                    Pdeposits := cust."Current Shares";
                end;

                if loanProducts."Deposits Multiplier" <= 0 then begin
                    Pdeposits := Pdeposits;
                end else
                    Pdeposits := (Pdeposits) * loanProducts."Deposits Multiplier";

                eligibleAmount := Round(FnReccommendAmount(loanProduct, requestedAmount, Pdeposits, requestedAmount, Psalary, Pdeposits), 0.01, '=');
                if eligible > 0 then begin
                    eligible := eligibleAmount;
                end else begin
                    eligible := loanProducts."Min. Loan Amount";
                end;
            end;
        end;
    end;

