                    LastRow := page_number * page_size;
                    TotalFoundRecords := CredLedger.Count;

                    repeat begin
                        Count := Count + 1;
                        if (Count >= FirstRow) and (Count <= LastRow) then begin
                            EntryType := '';
                            if CredLedger.Amount > 0 then
                                EntryType := 'Debit'
                            else
