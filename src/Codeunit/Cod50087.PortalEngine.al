    local procedure CreateNextOfKinApplicationRequest(RequestJson: JsonObject) ResponseJson: JsonObject
    var
        DataJson: JsonObject;
        IdentifierType: Text;
        Identifier: Text;
        Identifier2: Text;
        Identifier3: Text;
        idNo: Text;
        idValue: Text;
        alloc: Decimal;
        fullName: Text;
        relation: Text;
        dob: Date;
        address: Text;
        mobile: Text;
        email: Text;
        isNOK: Boolean;
        isbeneficiary: Boolean;
        isContactPerson: Boolean;
        isNominee: Boolean;
        NextKinJson: JsonObject;
        NOKApplicationArray: JsonObject;
        LoanObject: JsonObject;
        Iterator: Integer;
        Members: Record Customer;
        nokApplications: Record "NOK Applications";
        nokApplications2: Record "NOK Applications";
        nokIdTypes: Record "Portal Identification Types";
        NetKin: Record "Members Next of Kin";
        saccoGen: Record "Sacco No. Series";
        NextKin: JsonArray;
        noSeries: Codeunit "No. Series";
        appNo: Code[20];
        nokLists: JsonArray;
        totalAllocation: Decimal;
        errorText: Text[100];
        errorTextFinal: Text[100];
    begin
        Iterator := 0;
        alloc := 0;
        totalAllocation := 0;
        clear(nokLists);
        IdentifierType := SelectJsonToken(RequestJson, '$.identifier_type').AsValue.AsText;
        Identifier := SelectJsonToken(RequestJson, '$.identifier').AsValue.AsText;

        nokLists := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info').AsArray();
        Iterator := nokLists.Count;
        Iterator := Iterator - 1;
        while (Iterator >= 0) do begin
            idNo := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].identification_type').AsValue.AsText;
            idValue := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].identification_value').AsValue.AsText;
            fullName := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].full_names').AsValue.AsText;
            relation := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].relationship').AsValue.AsText;
            dob := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].date_of_birth').AsValue.AsDate;
            address := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].address').AsValue.AsText;
            mobile := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].mobile_no').AsValue.AsText;
            email := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].email_address').AsValue.AsText;
            isNOK := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].is_next_of_kin').AsValue.AsBoolean;
            isbeneficiary := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].is_beneficiary').AsValue.AsBoolean;
            isContactPerson := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].is_contact_person').AsValue.AsBoolean;
            isNominee := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].is_nominee').AsValue.AsBoolean;
            alloc := SelectJsonToken(RequestJson, '$.nok_beneficiary_nominee_info[' + Format(Iterator) + '].allocation').AsValue.AsDecimal;
            Iterator := Iterator - 1;
        end;

        // Clear(NextKinJson);
        Identifier2 := InsStr(Identifier, '+', 1);
        Identifier3 := DelChr(Identifier, '<', '254');
        Identifier3 := InsStr(Identifier3, '0', 1);

        if IdentifierType = 'MEMBER_NO' then begin
            Members.Reset();
            Members.SetRange("No.", Identifier);
            if Members.FindFirst() then begin

                NetKin.Reset();
                NetKin.SetRange("Account No", Members."No.");
                if NetKin.FindSet() then begin
                    NetKin.CalcSums("%Allocation");
                    totalAllocation := NetKin."%Allocation";
                end;

                if totalAllocation + alloc > 100 then begin
                    errorText := 'The % Allocation cannot exceed 100%. This application can only go upto %1% allocation.';
                    errorTextFinal := StrSubstNo(errorText, (100 - totalAllocation));
                    SetResponseStatus(ResponseJson, 'fail', 'Fail', errorTextFinal);
                end else if (alloc <= 0) and isbeneficiary then begin
                    errorTextFinal := 'A beneficiary needs a % allocation.';
                    SetResponseStatus(ResponseJson, 'error', 'Error', errorTextFinal);
                end else begin
                    // SetResponseStatus(ResponseJson, 'fail', 'Fail', 'IdNo: '+idNo+'');
                    nokApplications.Init();
                    saccoGen.Get();
                    appNo := noSeries.GetNextNo(saccoGen."NOK Application Nos", Today, true);
                    nokApplications."Application No" := appNo;
                    nokApplications."Member No" := Members."No.";
                    if nokIdTypes.Get(idNo) then begin
                        nokApplications.Identification := nokIdTypes.Code;
                    end;
                    nokApplications."Identification Value" := idValue;
                    nokApplications."Full Names" := fullName;
                    nokApplications.Relationship := relation;
                    nokApplications."Date of Birth" := dob;
                    nokApplications.Address := address;
                    nokApplications."Mobile Phone No" := mobile;
                    nokApplications."Email Address" := email;
                    nokApplications."Is Next of Kin" := isNOK;
                    nokApplications."Is Beneficiary" := isbeneficiary;
                    nokApplications."Is Contact Person" := isContactPerson;
                    nokApplications."Is Nominee" := isNominee;
                    nokApplications.Status := nokApplications.Status::Open;
                    nokApplications."% Allocation" := alloc;
                    nokApplications."Application Type" := nokApplications."Application Type"::New;
                    nokApplications."Date Applied" := Today;
                    nokApplications."Time Applied" := Time;
                    nokApplications."Captured By" := UserId;
                    nokApplications.Insert;

