        countDown: Integer;
        destAccType: Text;
        destAcc: Text;
        destAmount: Decimal;
        frequency: Text;
        dur: Text;
        durat: DateFormula;
        duratII: DateFormula;
        converted: Boolean;
        subguarantoramount: Decimal;
        guaranteedAmount: Decimal;
        HeaderAmount: Decimal;
        Identifier2: Text;
        Identifier3: Text;
