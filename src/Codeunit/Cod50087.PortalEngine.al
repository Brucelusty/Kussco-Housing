    local procedure FnPrepJournal(Template: Code[20]; Batch: Code[20])
    var
        myInt: Integer;
        docNo: Code[20];
        generalBatch: Record "Gen. Journal Batch";
        generalJournal: Record "Gen. Journal Line";
    begin
        generalJournal.Reset();
        generalJournal.SetRange("Journal Template Name", Template);
        generalJournal.SetRange("Journal Batch Name", Batch);
        if generalJournal.FindSet() then begin
            generalJournal.DeleteAll();
        end;

        generalBatch.Reset();
        generalBatch.SetRange("Journal Template Name", Template);
        generalBatch.SetRange(Name, Batch);
        if generalBatch.Find('-') = false then begin
            generalBatch.Init();
            generalBatch."Journal Template Name" := Template;
            generalBatch.Name := Batch;
            generalBatch.Description := 'Auto Disbursement of Portal Applied Loans';
            generalBatch.Insert();
        end;
    end;

