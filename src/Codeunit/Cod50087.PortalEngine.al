        desc := SelectJsonToken(RequestJson, '$.description').AsValue.AsText;
        HeaderAmount := SelectJsonToken(RequestJson, '$.amount').AsValue.AsDecimal;

        Identifier2 := InsStr(Identifier, '+', 1);
        Identifier3 := DelChr(Identifier, '<', '254');
        Identifier3 := InsStr(Identifier3, '0', 1);

        // stoDates.Reset();
        // stoDates.SetRange(Code, dur)
