        Identifier: Text;
        banksJson: JsonObject;
        Iterator: Integer;
        banks: Record "Banks Ver2";
        bank: JsonArray;
    begin
        Identifier := '';
        banks.Reset();
        if banks.FindSet() then begin
            repeat
                if Identifier <> banks."Bank Code" then begin
                    banksJson.Add('code', banks."Bank Code");
                    banksJson.Add('name', banks."Bank Name");
                    Identifier := banks."Bank Code";
                    bank.Add(banksJson);
                    Clear(banksJson);
