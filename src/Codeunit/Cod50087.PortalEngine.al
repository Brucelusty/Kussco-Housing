        fileName: Text;
        responseText: Text;
        desc: Text;
        effectiveDate: Date;
        Iterator: Integer;
        srcAccJson: JsonObject;
        stoLinesJson: JsonArray;
        srcJson: JsonArray;
        stoNo: Code[20];
        noSeriesMngt: Codeunit "No. Series";
        noSeries: Record "Sacco No. Series";
        cust: Record Customer;
        sto: Record "Standing Orders";
        stoLines: Record "Receipt Allocation";
        stoIncomes: Record "Portal Identification Types";
        vend: Record Vendor;
        accountTypes: Record "Account Types-Saving Products";
    begin
        Iterator := 0;
        HeaderAmount := 0;
        IdentifierType := SelectJsonToken(RequestJson, '$.identifier_type').AsValue.AsText;
        Identifier := SelectJsonToken(RequestJson, '$.identifier').AsValue.AsText;
        srcAcc := SelectJsonToken(RequestJson, '$.source_account').AsValue.AsText;
        incomeType := SelectJsonToken(RequestJson, '$.income_type').AsValue.AsCode;
